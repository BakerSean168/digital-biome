---
import type { AssetCard } from '../../types/notes';
import type { ResolvedTopologyNode } from '../../utils/infrastructure';
import InfrastructureTopologyMap, { type TopologyTier } from './InfrastructureTopologyMap.astro';
import { ArrowRight } from '@lucide/astro';

interface Props {
  title: string;
  description: string;
  resolvedNodes: Record<string, ResolvedTopologyNode>;
  featuredAssets: AssetCard[];
  heroFacts: string[];
  locale?: 'zh' | 'en';
}

const {
  title,
  description,
  resolvedNodes,
  featuredAssets,
  heroFacts,
  locale = 'zh',
} = Astro.props;

const localePrefix = locale === 'en' ? '/en' : '';

const labels = locale === 'en'
  ? {
      atlasTitle: 'Global Atlas',
      atlasDescription: 'An editorial overview of entry, public fleet, and homelab layers.',
      homelabTitle: 'Homelab View',
      homelabDescription: 'Read the home network as layered infrastructure.',
      fleetTitle: 'Fleet View',
      fleetDescription: 'See the public fleet as role-based regional nodes.',
    }
  : {
      atlasTitle: 'Global Atlas',
      atlasDescription: '先用一张总览图交代入口、控制平面、公网舰队和家庭实验室，再继续下钻到具体节点。',
      homelabTitle: 'Homelab View',
      homelabDescription: '把家庭网络拆成供电、网络、计算、虚拟化和服务五层，让它更像一套真正的 Homelab。',
      fleetTitle: 'Fleet View',
      fleetDescription: '把公网节点按角色和区域展开成舰队视图，而不是继续堆一串服务器列表。',
    };

function buildTiers(cards: any[]): TopologyTier[] {
  return cards.map(card => {
    const rawNodes = card.nodeIds
      .map((id: string) => resolvedNodes[id])
      .filter(Boolean) as ResolvedTopologyNode[];
    
    const items: {node: ResolvedTopologyNode, services: ResolvedTopologyNode[]}[] = [];
    let currentItem: {node: ResolvedTopologyNode, services: ResolvedTopologyNode[]} | null = null;
    
    for (const n of rawNodes) {
      if (n.kind === 'service' || n.kind === 'tool' || n.kind === 'vm') {
        if (currentItem) {
          currentItem.services.push(n);
        } else {
          items.push({ node: n, services: [] });
        }
      } else {
        currentItem = { node: n, services: [] };
        items.push(currentItem);
      }
    }

    return {
      id: card.eyebrow,
      title: card.title,
      description: card.description,
      items: items.length > 0 ? items : rawNodes.map(n => ({node: n, services: []}))
    };
  });
}

const atlasTiers = buildTiers(locale === 'en' ? [
  { eyebrow: 'Entry Layer', title: 'Domain, Edge, and Control', description: 'Traffic and management first converge on the domain edge, Cloudflare, and the Hong Kong control plane.', nodeIds: ['internet', 'bakersean-top-domain', 'cloudflare-edge', 'azure-hk-vps', 'sub-store', 'nezha-panel'] },
  { eyebrow: 'Public Fleet', title: 'Workloads, Proxies, and Public Sites', description: 'Business traffic, proxy nodes, and public showcase sites.', nodeIds: ['aliyun-chengdu-dailyuse-vps', 'memoflow-dailyuse', 'azure-japan-singbox-vps', 'azure-korea-singbox-vps', 'azure-hk-singbox-vps', 'digital-biome-site', 'github-profile-site'] },
  { eyebrow: 'Home Lab', title: 'Power, LAN, and Service Stack', description: 'The home lab combines a layered home network, a compact PVE stack, and a growing NAS service plane.', nodeIds: ['home-ups', 'home-optical-modem', 'home-switch', 'n100-host', 'pve-hypervisor', 'services-vm', 'fnos-vm', 'vaultwarden'] }
] : [
  { eyebrow: 'Entry', title: '入口与控制面', description: '外部访问先汇入域名层、Cloudflare 边缘层和香港控制平面。', nodeIds: ['internet', 'bakersean-top-domain', 'cloudflare-edge', 'azure-hk-vps', 'sub-store', 'nezha-panel'] },
  { eyebrow: 'Fleet', title: '公网舰队', description: '业务主机、区域代理节点和公开站点共同构成对外可见的 Public Fleet。', nodeIds: ['aliyun-chengdu-dailyuse-vps', 'memoflow-dailyuse', 'azure-japan-singbox-vps', 'azure-korea-singbox-vps', 'azure-hk-singbox-vps', 'digital-biome-site', 'github-profile-site'] },
  { eyebrow: 'Homelab', title: '家庭实验室', description: '家庭网络通过 UPS、主路由、交换层、PVE 虚拟化和 NAS 服务层形成一套 Homelab。', nodeIds: ['home-ups', 'home-optical-modem', 'home-switch', 'n100-host', 'pve-hypervisor', 'services-vm', 'fnos-vm', 'vaultwarden'] }
]);

const homelabTiers = buildTiers(locale === 'en' ? [
  { eyebrow: '01', title: 'Power Layer', nodeIds: ['utility-power', 'home-ups'] },
  { eyebrow: '02', title: 'Network Layer', nodeIds: ['home-optical-modem', 'router-vm', 'home-switch', 'home-ap'] },
  { eyebrow: '03', title: 'Compute Layer', nodeIds: ['n100-host', 'pve-hypervisor'] },
  { eyebrow: '04', title: 'Virtualization Layer', nodeIds: ['istoreos-vm', 'services-vm', 'fnos-vm'] },
  { eyebrow: '05', title: 'Service Layer', nodeIds: ['homepage-dashboard', 'vaultwarden', 'jellyfin-media-center', 'alist-media-gateway'] }
] : [
  { eyebrow: '01', title: '供电层', nodeIds: ['utility-power', 'home-ups'] },
  { eyebrow: '02', title: '网络层', nodeIds: ['home-optical-modem', 'router-vm', 'home-switch', 'home-ap'] },
  { eyebrow: '03', title: '计算层', nodeIds: ['n100-host', 'pve-hypervisor'] },
  { eyebrow: '04', title: '虚拟化层', nodeIds: ['istoreos-vm', 'services-vm', 'fnos-vm'] },
  { eyebrow: '05', title: '服务层', nodeIds: ['homepage-dashboard', 'vaultwarden', 'jellyfin-media-center', 'alist-media-gateway'] }
]);

const fleetTiers = buildTiers(locale === 'en' ? [
  { eyebrow: 'Control', title: 'Control Plane', nodeIds: ['azure-hk-vps', 'sub-store', 'nezha-panel'] },
  { eyebrow: 'Workload', title: 'Workload Plane', nodeIds: ['aliyun-chengdu-dailyuse-vps', 'memoflow-dailyuse'] },
  { eyebrow: 'Proxy', title: 'Proxy Fleet', nodeIds: ['azure-japan-singbox-vps', 'sing-box-japan', 'azure-korea-singbox-vps', 'sing-box-korea', 'azure-hk-singbox-vps', 'sing-box-hk'] },
  { eyebrow: 'Showcase', title: 'Public Sites', nodeIds: ['cloudflare-pages-host', 'digital-biome-site', 'github-profile-site'] }
] : [
  { eyebrow: 'Control', title: '香港控制平面', nodeIds: ['azure-hk-vps', 'sub-store', 'nezha-panel'] },
  { eyebrow: 'Workload', title: '成都业务节点', nodeIds: ['aliyun-chengdu-dailyuse-vps', 'memoflow-dailyuse'] },
  { eyebrow: 'Proxy', title: '区域代理集群', nodeIds: ['azure-japan-singbox-vps', 'sing-box-japan', 'azure-korea-singbox-vps', 'sing-box-korea', 'azure-hk-singbox-vps', 'sing-box-hk'] },
  { eyebrow: 'Showcase', title: '公开站点', nodeIds: ['cloudflare-pages-host', 'digital-biome-site', 'github-profile-site'] }
]);
---

<div class="flex flex-col gap-16 pb-16">
  <!-- Hero Section -->
  <section class="border-b border-border pb-10">
    <div class="mb-4">
      <span class="inline-block border border-primary/20 bg-primary/10 px-2 py-0.5 text-[10px] font-mono tracking-widest text-primary uppercase">
        {locale === 'en' ? 'INFRASTRUCTURE' : '数字基础设施'}
      </span>
    </div>
    
    <div class="flex flex-col md:flex-row gap-8 justify-between">
      <div class="flex-1">
        <h1 class="text-3xl md:text-5xl font-mono tracking-tight text-foreground">{title}</h1>
        <p class="mt-4 text-sm font-mono text-muted-foreground leading-relaxed max-w-2xl">
          {description}
        </p>
      </div>

      <div class="flex-1 max-w-sm">
        <div class="border border-border bg-background p-4 flex flex-col gap-3">
          <span class="text-[10px] font-mono text-muted-foreground uppercase tracking-widest">SYSTEM_FACTS</span>
          <ul class="flex flex-col gap-2">
            {heroFacts.map(fact => (
              <li class="flex items-start gap-2 text-[11px] font-mono text-foreground/80">
                <ArrowRight size={12} class="mt-0.5 text-primary shrink-0" />
                <span>{fact}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Global Atlas Map -->
  <InfrastructureTopologyMap
    title={labels.atlasTitle}
    description={labels.atlasDescription}
    tiers={atlasTiers}
  />

  <div class="h-px bg-border/50 w-full my-8"></div>

  <!-- Homelab Map -->
  <InfrastructureTopologyMap
    title={labels.homelabTitle}
    description={labels.homelabDescription}
    tiers={homelabTiers}
  />

  <div class="h-px bg-border/50 w-full my-8"></div>

  <!-- Fleet Map -->
  <InfrastructureTopologyMap
    title={labels.fleetTitle}
    description={labels.fleetDescription}
    tiers={fleetTiers}
  />
</div>
