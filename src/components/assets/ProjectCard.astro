---
import type { AssetCard as AssetCardType } from '../../types/notes';

interface Props {
  asset: AssetCardType;
}

const { asset } = Astro.props;
const primaryLink = asset.links.find(link => link.kind === 'app') ?? asset.links[0];
const repoLink = asset.links.find(link => link.kind === 'repo');
const docsLink = asset.links.find(link => link.kind === 'docs');
const hostname = (() => {
  if (!primaryLink?.url) {
    return undefined;
  }

  try {
    return new URL(primaryLink.url).hostname;
  } catch {
    return undefined;
  }
})();
const localIconUrl = hostname ? `/favicons/${hostname}.png` : undefined;
const fallbackIconUrl = hostname ? `https://www.google.com/s2/favicons?domain=${hostname}&sz=128` : undefined;

const roleMeta = asset.assetRole === 'product'
  ? {
      label: 'SYS.PRODUCT',
      chip: 'border-primary/30 text-primary',
    }
  : {
      label: 'SYS.SHOWCASE',
      chip: 'border-border text-muted-foreground',
    };
---

<article class="group relative overflow-hidden rounded-sm border border-border/80 bg-card/30 p-6 transition-all duration-300 hover:border-primary/50">
  <!-- Subtle top border highlight instead of gradient -->
  <div class="absolute inset-x-0 top-0 h-[1px] bg-gradient-to-r from-transparent via-primary/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
  
  <div class="relative flex items-start justify-between gap-4">
    <div class="min-w-0">
      <div class="mb-4 flex flex-wrap items-center gap-2">
        <span class={`border px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest ${roleMeta.chip}`}>
          {roleMeta.label}
        </span>
        {asset.status && (
          <span class="border border-border/50 px-2 py-0.5 font-mono text-[10px] uppercase text-muted-foreground/70">
            {asset.status}
          </span>
        )}
      </div>
      <h3 class="text-xl font-mono tracking-tight text-foreground group-hover:text-primary transition-colors">{asset.title}</h3>
      {asset.description && (
        <p class="mt-3 line-clamp-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
          {asset.description}
        </p>
      )}
    </div>

    {hostname && (
      <div class="flex h-12 w-12 shrink-0 items-center justify-center border border-border/60 bg-background shadow-sm transition-colors group-hover:border-primary/40">
        {localIconUrl && fallbackIconUrl && (
          <img
            src={localIconUrl}
            alt={`${asset.title} favicon`}
            class="h-6 w-6 object-contain grayscale transition-all duration-300 group-hover:grayscale-0"
            loading="lazy"
            onerror={`this.onerror=null; this.src='${fallbackIconUrl}';`}
          />
        )}
      </div>
    )}
  </div>

  <div class="relative mt-5 flex flex-wrap gap-x-3 gap-y-1">
    {asset.tags.slice(0, 4).map(tag => (
      <span class="font-mono text-[10px] text-muted-foreground/60 transition-colors hover:text-primary">
        #{tag.includes('/') ? tag.split('/').pop() : tag}
      </span>
    ))}
  </div>

  <div class="relative mt-6 flex flex-wrap gap-2">
    <a
      href={asset.href}
      class="inline-flex items-center border border-border px-3 py-1.5 font-mono text-[10px] tracking-widest uppercase text-muted-foreground transition-colors hover:border-primary/60 hover:text-primary"
    >
      [ DETAILS ]
    </a>
    {primaryLink && (
      <a
        href={primaryLink.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center border border-primary/40 px-3 py-1.5 font-mono text-[10px] tracking-widest uppercase text-primary transition-colors hover:bg-primary/10 hover:border-primary"
      >
        [ LAUNCH ]
      </a>
    )}
    {repoLink && (
      <a
        href={repoLink.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center border border-border px-3 py-1.5 font-mono text-[10px] tracking-widest uppercase text-muted-foreground transition-colors hover:border-primary/60 hover:text-primary"
      >
        [ REPO ]
      </a>
    )}
    {!repoLink && docsLink && (
      <a
        href={docsLink.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center border border-border px-3 py-1.5 font-mono text-[10px] tracking-widest uppercase text-muted-foreground transition-colors hover:border-primary/60 hover:text-primary"
      >
        [ DOCS ]
      </a>
    )}
  </div>
</article>
