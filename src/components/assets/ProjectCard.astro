---
import type { AssetCard as AssetCardType } from '../../types/notes';

interface Props {
  asset: AssetCardType;
}

const { asset } = Astro.props;
const primaryLink = asset.links.find(link => link.kind === 'app') ?? asset.links[0];
const repoLink = asset.links.find(link => link.kind === 'repo');
const docsLink = asset.links.find(link => link.kind === 'docs');
const hostname = (() => {
  if (!primaryLink?.url) {
    return undefined;
  }

  try {
    return new URL(primaryLink.url).hostname;
  } catch {
    return undefined;
  }
})();
const localIconUrl = hostname ? `/favicons/${hostname}.png` : undefined;
const fallbackIconUrl = hostname ? `https://www.google.com/s2/favicons?domain=${hostname}&sz=128` : undefined;
const roleMeta = asset.assetRole === 'product'
  ? {
      label: 'PRODUCT',
      accent: 'from-cyan-500/20 via-transparent to-emerald-500/10',
      chip: 'border-cyan-400/25 bg-cyan-400/10 text-cyan-200',
    }
  : {
      label: 'SHOWCASE',
      accent: 'from-amber-500/20 via-transparent to-pink-500/10',
      chip: 'border-amber-400/25 bg-amber-400/10 text-amber-200',
    };
---

<article class="group relative overflow-hidden rounded-[32px] border border-border/80 bg-[linear-gradient(180deg,rgba(255,255,255,0.04),rgba(255,255,255,0.02))] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-primary/35 hover:shadow-[0_22px_70px_rgba(0,0,0,0.12)]">
  <div class={`absolute inset-x-0 top-0 h-24 bg-gradient-to-r ${roleMeta.accent} opacity-90`}></div>
  <div class="relative flex items-start justify-between gap-4">
    <div class="min-w-0">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <span class={`rounded-full border px-3 py-1 text-[11px] font-medium uppercase tracking-[0.22em] ${roleMeta.chip}`}>
          {roleMeta.label}
        </span>
        {asset.status && (
          <span class="rounded-full border border-border px-3 py-1 text-[11px] text-muted-foreground">
            {asset.status}
          </span>
        )}
      </div>
      <h3 class="text-2xl font-semibold tracking-tight text-foreground">{asset.title}</h3>
      {asset.description && (
        <p class="mt-3 line-clamp-3 max-w-2xl text-sm leading-6 text-muted-foreground">
          {asset.description}
        </p>
      )}
    </div>

    {hostname && (
      <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-border bg-card/80 shadow-sm">
        {localIconUrl && fallbackIconUrl && (
          <img
            src={localIconUrl}
            alt={`${asset.title} favicon`}
            class="h-7 w-7 object-contain"
            loading="lazy"
            onerror={`this.onerror=null; this.src='${fallbackIconUrl}';`}
          />
        )}
      </div>
    )}
  </div>

  <div class="relative mt-4 flex flex-wrap gap-2">
    {asset.tags.slice(0, 4).map(tag => (
      <span class="rounded-full bg-pane/90 px-2.5 py-1 text-xs text-muted-foreground">
        #{tag.includes('/') ? tag.split('/').pop() : tag}
      </span>
    ))}
  </div>

  <div class="relative mt-6 flex flex-wrap gap-2">
    <a
      href={asset.href}
      class="inline-flex items-center rounded-full border border-border px-4 py-2 text-sm text-foreground transition-colors hover:border-primary/40 hover:text-primary"
    >
      查看详情
    </a>
    {primaryLink && (
      <a
        href={primaryLink.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-full bg-foreground px-4 py-2 text-sm font-medium text-background transition-colors hover:bg-primary"
      >
        {primaryLink.label}
      </a>
    )}
    {repoLink && (
      <a
        href={repoLink.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-full border border-border px-4 py-2 text-sm text-muted-foreground transition-colors hover:border-primary/40 hover:text-primary"
      >
        {repoLink.label}
      </a>
    )}
    {!repoLink && docsLink && (
      <a
        href={docsLink.url}
        class="inline-flex items-center rounded-full border border-border px-4 py-2 text-sm text-muted-foreground transition-colors hover:border-primary/40 hover:text-primary"
      >
        {docsLink.label}
      </a>
    )}
  </div>
</article>
