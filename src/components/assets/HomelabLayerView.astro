---
import AssetSection from './AssetSection.astro';
import InfrastructureNodePanel from './InfrastructureNodePanel.astro';
import type { AssetCard } from '../../types/notes';
import type { HomelabLayer, ResolvedTopologyNode } from '../../utils/infrastructure';

interface Props {
  title: string;
  description: string;
  layers: HomelabLayer[];
  resolvedNodes: Record<string, ResolvedTopologyNode>;
  assets: AssetCard[];
  locale?: 'zh' | 'en';
}

interface HomelabPath {
  title: string;
  description: string;
  nodeIds: string[];
}

const {
  title,
  description,
  layers,
  resolvedNodes,
  assets,
  locale = 'zh',
} = Astro.props;

const labels = locale === 'en'
  ? {
      eyebrow: 'Homelab Layered View',
      stackTitle: 'Layer Stack',
      stackDescription: 'Read the lab from bottom to top: power keeps it alive, network connects it, compute hosts it, virtualization segments it, and services make it useful.',
      pathTitle: 'Critical Paths',
      pathDescription: 'Two paths explain how the home lab behaves as a real environment rather than a random box of services.',
      linkedAssets: 'Homelab Assets',
      linkedDescription: 'Each linked asset can still be maintained independently as a note, while this page presents the system-level picture.',
      linkedHrefLabel: 'Open infrastructure search',
      detailLink: 'detail',
      openLink: 'open',
      empty: 'No homelab assets are linked yet.',
      facts: [
        `${layers.length} infrastructure layers`,
        `${layers.reduce((sum, layer) => sum + layer.nodeIds.length, 0)} mapped nodes`,
        `${assets.length} asset-backed entries`,
        'power -> network -> compute -> vm -> service',
      ],
      paths: [
        {
          title: 'Operational Path',
          description: 'The path from protected power to daily service entry.',
          nodeIds: ['home-ups', 'home-optical-modem', 'home-switch', 'n100-host', 'pve-hypervisor', 'services-vm', 'homepage-dashboard', 'vaultwarden'],
        },
        {
          title: 'Media Path',
          description: 'The path from the virtualization backbone into the future NAS media surface.',
          nodeIds: ['n100-host', 'pve-hypervisor', 'fnos-vm', 'alist-media-gateway', 'jellyfin-media-center', 'qbittorrent-downloader'],
        },
      ] satisfies HomelabPath[],
    }
  : {
      eyebrow: 'Homelab Layered View',
      stackTitle: '分层主剖面',
      stackDescription: '从下往上读这套实验室：供电先保证它活着，网络负责把它连起来，计算层承载它，虚拟化层拆分它，服务层才真正把它变得可用。',
      pathTitle: '关键路径',
      pathDescription: '下面两条路径用来解释这套 Homelab 作为“系统”是怎么运作的，而不是简单罗列设备和服务名。',
      linkedAssets: 'Homelab 关联资产',
      linkedDescription: '这些资产仍然保留为独立笔记维护，而这张页面负责把它们提升成一套系统级视图。',
      linkedHrefLabel: '进入基础设施搜索',
      detailLink: '详情',
      openLink: '入口',
      empty: '还没有接入 Homelab 资产。',
      facts: [
        `${layers.length} 层基础设施分层`,
        `${layers.reduce((sum, layer) => sum + layer.nodeIds.length, 0)} 个已绘制节点`,
        `${assets.length} 个已资产化入口`,
        'power -> network -> compute -> vm -> service',
      ],
      paths: [
        {
          title: '运行主路径',
          description: '从受保护供电一路进入日常服务入口的关键路径。',
          nodeIds: ['home-ups', 'home-optical-modem', 'home-switch', 'n100-host', 'pve-hypervisor', 'services-vm', 'homepage-dashboard', 'vaultwarden'],
        },
        {
          title: '媒体路径',
          description: '从虚拟化底座一路进入未来 NAS 媒体服务面的关键路径。',
          nodeIds: ['n100-host', 'pve-hypervisor', 'fnos-vm', 'alist-media-gateway', 'jellyfin-media-center', 'qbittorrent-downloader'],
        },
      ] satisfies HomelabPath[],
    };

const layerViews = layers.map(layer => ({
  ...layer,
  nodes: layer.nodeIds
    .map(nodeId => resolvedNodes[nodeId])
    .filter((node): node is ResolvedTopologyNode => Boolean(node)),
}));

const pathViews = labels.paths.map(path => ({
  ...path,
  nodes: path.nodeIds
    .map(nodeId => resolvedNodes[nodeId])
    .filter((node): node is ResolvedTopologyNode => Boolean(node)),
}));
---

<div class="space-y-10">
  <section class="relative overflow-hidden rounded-[36px] border border-border bg-card/70 px-6 py-8 md:px-9 md:py-10">
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.022)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.022)_1px,transparent_1px)] bg-[size:24px_24px] opacity-35"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(14,165,233,0.14),transparent_25%),radial-gradient(circle_at_bottom_right,rgba(132,204,22,0.12),transparent_28%)]"></div>
    <div class="relative">
      <p class="text-sm uppercase tracking-[0.28em] text-primary/80">{labels.eyebrow}</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-foreground md:text-5xl">{title}</h1>
      <p class="mt-4 max-w-4xl text-base leading-7 text-muted-foreground md:text-lg">{description}</p>

      <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        {labels.facts.map(fact => (
          <div class="rounded-2xl border border-border bg-background/65 px-4 py-3 text-sm text-muted-foreground shadow-[0_12px_40px_rgba(0,0,0,0.08)]">
            {fact}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="space-y-6">
    <div>
      <p class="text-xs uppercase tracking-[0.24em] text-primary/75">{labels.pathTitle}</p>
      <h2 class="mt-2 text-2xl font-semibold text-foreground md:text-3xl">{labels.pathTitle}</h2>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">{labels.pathDescription}</p>
    </div>

    <div class="grid gap-5 xl:grid-cols-2">
      {pathViews.map(path => (
        <article class="rounded-[32px] border border-border bg-card/70 p-5 md:p-6">
          <h3 class="text-xl font-semibold text-foreground">{path.title}</h3>
          <p class="mt-2 text-sm leading-6 text-muted-foreground">{path.description}</p>

          <div class="mt-5 flex flex-col gap-3">
            {path.nodes.map((node, index) => (
              <Fragment>
                <div class="rounded-2xl border border-border bg-background/70 px-4 py-3">
                  <div class="flex items-center justify-between gap-3">
                    <div class="min-w-0">
                      <p class="text-[10px] uppercase tracking-[0.18em] text-muted-foreground">{node.kind}</p>
                      <p class="truncate text-sm font-medium text-foreground">{node.title}</p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                      {node.href && <a href={node.href} class="text-xs text-primary transition-colors hover:text-foreground">{labels.detailLink}</a>}
                      {node.primaryUrl && <a href={node.primaryUrl} target="_blank" rel="noopener noreferrer" class="text-xs text-muted-foreground transition-colors hover:text-primary">{labels.openLink}</a>}
                    </div>
                  </div>
                </div>

                {index < path.nodes.length - 1 && (
                  <div class="flex justify-center">
                    <div class="h-6 w-px bg-gradient-to-b from-primary/15 via-primary/50 to-primary/15"></div>
                  </div>
                )}
              </Fragment>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="space-y-6">
    <div>
      <p class="text-xs uppercase tracking-[0.24em] text-primary/75">{labels.stackTitle}</p>
      <h2 class="mt-2 text-2xl font-semibold text-foreground md:text-3xl">{labels.stackTitle}</h2>
      <p class="mt-2 max-w-4xl text-sm leading-6 text-muted-foreground">{labels.stackDescription}</p>
    </div>

    <div class="space-y-4">
      {layerViews.map((layer, index) => (
        <Fragment>
          <article class="relative overflow-hidden rounded-[36px] border border-border bg-card/72 p-5 md:p-7">
            <div class={`absolute inset-x-0 top-0 h-24 bg-gradient-to-r ${layer.accentClass}`}></div>

            <div class="relative grid gap-6 xl:grid-cols-[240px_minmax(0,1fr)] xl:gap-8">
              <div class="space-y-4">
                <div class="flex items-center gap-4">
                  <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-border bg-background/75 text-xl font-semibold text-foreground shadow-[0_10px_30px_rgba(0,0,0,0.08)]">
                    {layer.level}
                  </div>
                  <div>
                    <p class="text-xs uppercase tracking-[0.24em] text-primary/75">{locale === 'en' ? 'Infrastructure Layer' : '基础设施分层'}</p>
                    <h3 class="mt-1 text-2xl font-semibold text-foreground">{locale === 'en' ? layer.titleEn : layer.title}</h3>
                  </div>
                </div>

                <p class="text-sm leading-6 text-muted-foreground">
                  {locale === 'en' ? layer.descriptionEn : layer.description}
                </p>

                <div class="rounded-2xl border border-border bg-background/65 px-4 py-3 text-sm leading-6 text-muted-foreground">
                  {locale === 'en' ? layer.spotlightEn : layer.spotlight}
                </div>
              </div>

              <div class="grid gap-4 md:grid-cols-2 2xl:grid-cols-3">
                {layer.nodes.map(node => (
                  <InfrastructureNodePanel node={node} locale={locale} compact />
                ))}
              </div>
            </div>
          </article>

          {index < layerViews.length - 1 && (
            <div class="flex justify-center py-1">
              <div class="flex flex-col items-center gap-2">
                <div class="h-8 w-px bg-gradient-to-b from-primary/20 via-primary/55 to-primary/20"></div>
                <span class="rounded-full border border-border bg-background/70 px-3 py-1 text-[11px] uppercase tracking-[0.18em] text-muted-foreground">
                  {locale === 'en' ? 'next layer' : '下一层'}
                </span>
              </div>
            </div>
          )}
        </Fragment>
      ))}
    </div>
  </section>

  <AssetSection
    title={labels.linkedAssets}
    description={labels.linkedDescription}
    assets={assets}
    href={locale === 'en' ? '/en/discover' : '/discover'}
    hrefLabel={labels.linkedHrefLabel}
    emptyText={labels.empty}
  />
</div>
