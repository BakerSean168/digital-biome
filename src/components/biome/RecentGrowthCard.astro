---
import { ArrowUpRight } from '@lucide/astro';

interface Props {
  title: string;
  excerpt: string;
  meta: string;
  label: string;
  href: string;
  accent: string;
  glow: string;
  icon: any;
  tone?: string;
}

const {
  title,
  excerpt,
  meta,
  label,
  href,
  accent,
  glow,
  icon: Icon,
  tone = 'from-cyan-500/30 via-slate-900/20 to-slate-950/80',
} = Astro.props;
---

<a
  href={href}
  class="biome-growth-card group block overflow-hidden rounded-[26px] p-4 transition duration-500 hover:-translate-y-1"
  style={`--branch-accent: ${accent}; --branch-glow: ${glow};`}
>
  <div class={`relative overflow-hidden rounded-[22px] border border-white/8 bg-gradient-to-br ${tone} p-5`}>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.18),transparent_40%),linear-gradient(180deg,transparent,rgba(2,6,23,0.7))]"></div>
    <div class="relative flex min-h-[10.5rem] flex-col justify-between gap-10">
      <div class="flex items-start justify-between gap-3">
        <div class="flex items-center gap-2.5 text-sm text-white/72">
          <span class="flex h-9 w-9 items-center justify-center rounded-full border border-white/12 bg-white/7" style={`color: ${accent};`}>
            <Icon size={18} />
          </span>
          <span>{label}</span>
        </div>
        <span class="rounded-full border border-white/10 bg-white/[0.05] p-2 text-white/48 transition group-hover:text-white/80">
          <ArrowUpRight size={16} />
        </span>
      </div>

      <div>
        <h3 class="max-w-[18rem] text-[1.45rem] font-medium leading-tight tracking-tight text-white/94">
          {title}
        </h3>
        <p class="mt-3 max-w-[18rem] text-sm leading-6 text-white/60">
          {excerpt}
        </p>
      </div>
    </div>
  </div>

  <div class="mt-4 flex items-center justify-between gap-4 px-1">
    <span class="text-sm text-white/50">{meta}</span>
    <span class="text-sm text-white/38 transition group-hover:text-white/78">
      继续生长
    </span>
  </div>
</a>
