---
import { getBacklinksForNote, buildKnowledgeNoteHref } from '../../utils/notes';
import { CornerLeftUp } from '@lucide/astro';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const backlinks = getBacklinksForNote(currentSlug);
---

{backlinks.length > 0 ? (
  <ul class="m-0 p-0 list-none space-y-2.5 font-mono text-xs">
    {backlinks.map((note) => (
      <li class="flex items-start gap-1">
        <CornerLeftUp size={12} class="mt-0.5 text-text-muted shrink-0" />
        <a
          href={buildKnowledgeNoteHref(note.id)}
          class="text-foreground/80 hover:text-primary transition-colors duration-150 break-all leading-tight"
          title={note.description || note.title}
        >
          {note.title}
        </a>
      </li>
    ))}
  </ul>
) : (
  <div class="text-xs text-text-muted/50 font-mono italic pl-4">无上游引用</div>
)}
