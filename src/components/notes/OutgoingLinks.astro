---
import { getPublicNotes, getOutgoingLinksForNote } from '../../utils/notes';
import { CornerRightDown } from '@lucide/astro';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const allNotes = await getPublicNotes();
const currentNote = allNotes.find(note => note.id === currentSlug);
const outgoing = currentNote ? getOutgoingLinksForNote(currentNote, allNotes) : [];
---

{outgoing.length > 0 ? (
  <ul class="m-0 p-0 list-none space-y-2.5 font-mono text-xs">
    {outgoing.map((note) => (
      <li class="flex items-start gap-1">
        <CornerRightDown size={12} class="mt-0.5 text-text-muted shrink-0" />
        <a 
          href={`/notes/${note.id}`} 
          class="text-foreground/80 hover:text-primary transition-colors duration-150 break-all leading-tight"
          title={note.data.description || note.data.title}
        >
          {note.data.title}
        </a>
      </li>
    ))}
  </ul>
) : (
  <div class="text-xs text-text-muted/50 font-mono italic pl-4">无下游关联</div>
)}
