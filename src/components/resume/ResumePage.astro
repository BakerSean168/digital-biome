---
import { ArrowLeft, Printer } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
  backHref: string;
  backLabel: string;
  description: string;
  printLabel: string;
  title: string;
}

const { backHref, backLabel, description, printLabel, title } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <main
    id="resume-wrapper"
    class="max-w-[800px] mx-auto py-6 px-4 text-[12.5px] leading-[1.6] text-foreground print:max-w-none print:w-full print:p-0 print:text-black"
  >
    <slot />

    <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10 pt-6 border-t border-border print:hidden">
      <button
        onclick="window.print()"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary text-white rounded-lg font-medium transition-opacity hover:opacity-80"
      >
        <Printer size={18} /> {printLabel}
      </button>
      <a
        href={backHref}
        class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-transparent border-2 border-border text-foreground hover:bg-card hover:text-primary rounded-lg font-medium transition-colors"
      >
        <ArrowLeft size={18} /> {backLabel}
      </a>
    </div>
  </main>
</BaseLayout>

<style is:global>
  @media print {
    @page {
      size: A4 portrait;
      margin: 8mm 15mm;
    }

    html,
    body {
      background: white !important;
      color: black !important;
      margin: 0 !important;
      padding: 0 !important;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif !important;
    }

    body > header,
    body > footer,
    nav,
    aside,
    .print\:hidden {
      display: none !important;
    }

    #resume-wrapper {
      width: 100% !important;
      max-width: none !important;
      margin: 0 !important;
      padding: 0 !important;
      box-shadow: none !important;
      font-size: 12px;
      line-height: 1.5;
    }

    #resume-wrapper > div:first-child {
      margin-bottom: 10px !important;
    }

    .print-title-bg {
      background-color: #f5f5f5 !important;
      border: none !important;
      height: 22px !important;
      margin-bottom: 5px !important;
      page-break-after: avoid;
      break-after: avoid;
      break-inside: avoid;
    }

    .print-title-bg h2,
    .print-title-bg * {
      background-color: transparent !important;
    }

    .print-title-bar {
      background-color: #000 !important;
    }

    section {
      margin-bottom: 12px !important;
      page-break-inside: auto;
      break-inside: auto;
    }

    article {
      margin-bottom: 8px !important;
      page-break-inside: auto;
      break-inside: auto;
    }

    p,
    li {
      orphans: 2;
      widows: 2;
    }

    p,
    li,
    .keep-together {
      page-break-inside: avoid;
      break-inside: avoid;
    }

    h2,
    h3 {
      page-break-after: avoid;
      break-after: avoid;
    }

    a {
      text-decoration: none !important;
      color: black !important;
    }
  }
</style>
