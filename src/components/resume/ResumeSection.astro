---
interface Props {
  className?: string;
  title: string;
}

const { className, title } = Astro.props;
---

<section class:list={['mb-4', className]}>
  <div class="flex items-center bg-background-secondary h-[24px] mb-2 print-title-bg">
    <div class="w-[4px] h-[14px] bg-primary mr-2 print-title-bar"></div>
    <h2 class="text-[13.5px] font-bold text-foreground print:text-black tracking-widest leading-none !bg-transparent print:!bg-transparent">
      {title}
    </h2>
  </div>

  <slot />
</section>
