---
// ScrollingTagWall.astro
// Full-bleed background scrolling marquee tag wall in Basalt & Moss style
interface Props {
  tags: [string, number][];
  lang?: 'zh' | 'en';
}

const { tags, lang = 'zh' } = Astro.props;

// Process and format tags
const formattedTags = tags.map(([name, count]) => {
  const leafName = name.includes('/') ? name.split('/').pop() : name;
  return {
    name,
    leafName,
    count,
    href: lang === 'zh' ? `/notes?tag=${encodeURIComponent(name)}` : `/en/notes?tag=${encodeURIComponent(name)}`
  };
});

// Distribute tags across 8 lanes for high vertical coverage of the entire screen
const lane1 = formattedTags.filter((_, idx) => idx % 8 === 0);
const lane2 = formattedTags.filter((_, idx) => idx % 8 === 1);
const lane3 = formattedTags.filter((_, idx) => idx % 8 === 2);
const lane4 = formattedTags.filter((_, idx) => idx % 8 === 3);
const lane5 = formattedTags.filter((_, idx) => idx % 8 === 4);
const lane6 = formattedTags.filter((_, idx) => idx % 8 === 5);
const lane7 = formattedTags.filter((_, idx) => idx % 8 === 6);
const lane8 = formattedTags.filter((_, idx) => idx % 8 === 7);
---

<div class="absolute inset-0 w-full h-full overflow-hidden flex flex-col justify-between py-12 select-none z-0 pointer-events-none">
  
  <!-- Boundary Vignette Gradients (Fade-out effect at boundaries) -->
  <div class="absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-background to-transparent pointer-events-none z-10"></div>
  <div class="absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-background to-transparent pointer-events-none z-10"></div>
  
  <!-- Lane 1: Right to Left -->
  <div class="marquee-lane relative flex overflow-hidden w-full pointer-events-none">
    <div class="flex gap-8 animate-marquee-left shrink-0 min-w-full" style="--speed: 140s;">
      <div class="flex gap-8 shrink-0">
        {lane1.map(tag => (
          <a href={tag.href} class="tag-node group/tag pointer-events-auto">
            <span class="text-primary/50 group-hover/tag:text-primary transition-colors">#</span>
            <span>{tag.leafName}</span>
            <span class="tag-badge">[{tag.count}]</span>
          </a>
        ))}
      </div>
      <div class="flex gap-8 shrink-0">
