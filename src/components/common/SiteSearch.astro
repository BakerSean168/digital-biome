---
// SiteSearch.astro
// Custom Command Palette: Merges command routing (/tools, /dev) and full-text search (Pagefind).
---

<div id="search-modal" class="fixed inset-0 z-[100] hidden bg-background/80 backdrop-blur-sm transition-opacity" aria-hidden="true">
  <div class="fixed inset-0 z-[101] flex items-start justify-center pt-20 sm:pt-24">
    <div 
      id="search-container"
      class="w-full max-w-2xl overflow-hidden rounded-sm border border-border/80 bg-card/95 backdrop-blur-xl shadow-2xl transition-all sm:mx-6 flex flex-col"
      role="dialog"
      aria-modal="true"
      aria-label="Command Palette"
    >
      <!-- Input Area -->
      <div class="relative flex items-center border-b border-border/50 px-4 py-4">
        <span class="text-primary/70 font-mono mr-3">&gt;</span>
        <input 
          id="cmd-input" 
          type="text" 
          class="w-full bg-transparent font-mono text-sm text-foreground outline-none placeholder:text-muted-foreground/50" 
          placeholder="Enter command or search query... (e.g. /tools, PVE)"
          autocomplete="off"
          spellcheck="false"
        />
        <div id="cmd-loading" class="hidden absolute right-4">
          <span class="inline-block w-2 h-4 bg-primary/70 animate-[pulse_1s_step-end_infinite]"></span>
        </div>
      </div>
      
      <!-- Results Area -->
      <div id="cmd-results" class="max-h-[60vh] overflow-y-auto p-2 scrollbar-hide">
        <!-- JS will populate results here -->
      </div>
      
      <!-- Footer -->
      <div class="border-t border-border/50 px-4 py-2 bg-muted/10 text-[10px] text-muted-foreground font-mono flex justify-between">
        <span class="flex gap-4">
          <span><kbd class="border border-border/50 rounded px-1 text-[9px] mr-1">ESC</kbd>CLOSE</span>
          <span><kbd class="border border-border/50 rounded px-1 text-[9px] mr-1">↑↓</kbd>NAVIGATE</span>
          <span><kbd class="border border-border/50 rounded px-1 text-[9px] mr-1">↵</kbd>EXECUTE</span>
        </span>
        <span class="opacity-50 hidden sm:inline-block">SYS.COMMAND_CENTER</span>
      </div>
    </div>
  </div>
</div>

<style>
  .scrollbar-hide {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const ROUTES = [
    { type: 'cmd', label: 'NAV', title: '首页 / Home', desc: 'Return to Digital Biome root', href: '/' },
    { type: 'cmd', label: 'NAV', title: '工具导航 / Tools', desc: 'External bookmarks and tools', href: '/tools', alias: ['/tools', 'tools', 'nav'] },
    { type: 'cmd', label: 'NAV', title: '我的项目 / Dev', desc: 'Development showcase and apps', href: '/dev', alias: ['/dev', 'dev', 'projects'] },
    { type: 'cmd', label: 'NAV', title: '基础设施 / Infrastructure', desc: 'Homelab and public fleet', href: '/infrastructure', alias: ['/infrastructure', 'lab', 'ops', 'services'] },
    { type: 'cmd', label: 'NAV', title: '资产发现 / Discover', desc: 'Global index search', href: '/discover', alias: ['/discover', 'search'] },
    { type: 'cmd', label: 'NAV', title: '知识笔记 / Notes', desc: 'Obsidian vault notes', href: '/notes', alias: ['/notes', 'mind'] },
    { type: 'cmd', label: 'NAV', title: '关于宿主 / About', desc: 'Author profile', href: '/about', alias: ['/about', 'user'] },
  ];

  let pagefindInstance: any = null;
  const searchModal = document.getElementById('search-modal');
  const searchTriggers = document.querySelectorAll('.search-trigger');
  const cmdInput = document.getElementById('cmd-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('cmd-results');
  const loadingIndicator = document.getElementById('cmd-loading');
  
  let selectedIndex = 0;
  let currentResults: any[] = [];

  async function loadPagefind() {
    if (pagefindInstance) return pagefindInstance;
    try {
      // Bypass Vite's static analysis by using a variable
      const pfUrl = '/pagefind/pagefind.js';
      // @ts-ignore
      pagefindInstance = await import(/* @vite-ignore */ pfUrl);
      await pagefindInstance.init();
      return pagefindInstance;
    } catch (e) {
      console.warn('Pagefind is not available in dev mode.', e);
      return null;
    }
  }

  function renderResults() {
    if (!resultsContainer) return;
    resultsContainer.innerHTML = '';
    
    if (currentResults.length === 0) {
      resultsContainer.innerHTML = `
        <div class="px-4 py-8 text-center font-mono text-xs text-muted-foreground">
          SYS.WARN: NO_MATCH_FOUND
        </div>
      `;
      return;
    }

    const fragment = document.createDocumentFragment();
    currentResults.forEach((item, index) => {
      const el = document.createElement('div');
      const isSelected = index === selectedIndex;
      el.className = `group flex items-center justify-between p-3 cursor-pointer border-l-2 transition-colors ${
        isSelected ? 'border-primary bg-primary/10' : 'border-transparent hover:bg-card-hover/50'
      }`;
      el.dataset.index = index.toString();
      
      const leftCol = document.createElement('div');
      leftCol.className = 'flex items-center gap-3 min-w-0';
      leftCol.innerHTML = `
        <span class="shrink-0 text-[9px] font-mono tracking-widest border border-border/50 px-1.5 py-0.5 rounded-sm ${item.type === 'cmd' ? 'text-primary border-primary/30 bg-primary/5' : 'text-muted-foreground'}">
          [ ${item.label} ]
        </span>
        <div class="min-w-0 flex flex-col">
          <span class="font-mono text-sm truncate transition-colors ${isSelected ? 'text-primary' : 'text-foreground'}">${item.title}</span>
          ${item.desc ? `<span class="font-mono text-[10px] text-muted-foreground truncate mt-0.5">${item.desc}</span>` : ''}
        </div>
      `;
      
      const rightCol = document.createElement('div');
      rightCol.className = `shrink-0 font-mono text-[10px] text-primary transition-opacity ${isSelected ? 'opacity-100' : 'opacity-0 group-hover:opacity-100'}`;
      rightCol.textContent = '↵ EXECUTE';
      
      el.appendChild(leftCol);
      el.appendChild(rightCol);
      
      el.addEventListener('mouseenter', () => {
        selectedIndex = index;
        updateSelection();
      });
      el.addEventListener('click', () => {
        executeItem(index);
      });
      
      fragment.appendChild(el);
    });
    
    resultsContainer.appendChild(fragment);
    
    // Auto scroll to selection
    const selectedEl = resultsContainer.children[selectedIndex];
    if (selectedEl) {
      selectedEl.scrollIntoView({ block: 'nearest' });
    }
  }

  function updateSelection() {
    if (!resultsContainer) return;
    Array.from(resultsContainer.children).forEach((child, index) => {
      const el = child as HTMLElement;
      if (index === selectedIndex) {
        el.classList.add('border-primary', 'bg-primary/10');
        el.classList.remove('border-transparent', 'hover:bg-card-hover/50');
        const rightCol = el.lastElementChild as HTMLElement;
        if (rightCol) rightCol.classList.add('opacity-100');
        if (rightCol) rightCol.classList.remove('opacity-0', 'group-hover:opacity-100');
        
        const titleSpan = el.querySelector('.text-foreground, .text-primary');
        if (titleSpan) {
          titleSpan.classList.add('text-primary');
          titleSpan.classList.remove('text-foreground');
        }
      } else {
        el.classList.remove('border-primary', 'bg-primary/10');
        el.classList.add('border-transparent', 'hover:bg-card-hover/50');
        const rightCol = el.lastElementChild as HTMLElement;
        if (rightCol) rightCol.classList.remove('opacity-100');
        if (rightCol) rightCol.classList.add('opacity-0', 'group-hover:opacity-100');
        
        const titleSpan = el.querySelector('.text-foreground, .text-primary');
        if (titleSpan) {
          titleSpan.classList.remove('text-primary');
          titleSpan.classList.add('text-foreground');
        }
      }
    });
  }

  function executeItem(index: number) {
    const item = currentResults[index];
    if (item && item.href) {
      window.location.href = item.href;
    }
  }

  let debounceTimer: any = null;

  async function handleSearch(query: string) {
    loadingIndicator?.classList.remove('hidden');
    
    const lowerQuery = query.toLowerCase().trim();
    let results: any[] = [];
    
    // 1. Filter local routes/commands
    if (lowerQuery) {
      const cmdMatches = ROUTES.filter(r => {
        return r.title.toLowerCase().includes(lowerQuery) || 
               (r.alias && r.alias.some(a => a.includes(lowerQuery)));
      });
      results.push(...cmdMatches);
    } else {
      results.push(...ROUTES);
    }
    
    // 2. Pagefind search
    if (lowerQuery && !lowerQuery.startsWith('/')) {
      const pf = await loadPagefind();
      if (pf) {
        try {
          const search = await pf.search(lowerQuery);
          const rawResults = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));
          const pfResults = rawResults.map(item => ({
            type: 'search',
            label: 'DOC',
            title: item.meta?.title || item.url.split('/').pop()?.replace(/-/g, ' ') || 'Untitled',
            desc: item.excerpt ? item.excerpt.replace(/<[^>]*>?/gm, '') : '',
            href: item.url
          }));
          results.push(...pfResults);
        } catch (e) {
          console.error(e);
        }
      }
    }
    
    currentResults = results;
    selectedIndex = 0;
    loadingIndicator?.classList.add('hidden');
    renderResults();
  }

  function openModal() {
    if (!searchModal) return;
    searchModal.classList.remove('hidden');
    searchModal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    if (cmdInput) {
      cmdInput.value = '';
      cmdInput.focus();
      handleSearch('');
    }
  }

  function closeModal() {
    if (!searchModal) return;
    searchModal.classList.add('hidden');
    searchModal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Bind Events
  searchTriggers.forEach(trigger => {
    trigger.addEventListener('click', openModal);
  });

  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal || e.target === searchModal.firstElementChild) {
      closeModal();
    }
  });

  cmdInput?.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    const val = target.value;
    if (debounceTimer) clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      handleSearch(val);
    }, 200);
  });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (searchModal?.classList.contains('hidden')) {
        openModal();
      } else {
        closeModal();
      }
    }
    
    if (searchModal?.classList.contains('hidden')) return;
    
    if (e.key === 'Escape') {
      e.preventDefault();
      closeModal();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (selectedIndex < currentResults.length - 1) {
        selectedIndex++;
        updateSelection();
        const selectedEl = resultsContainer?.children[selectedIndex] as HTMLElement;
        if (selectedEl) selectedEl.scrollIntoView({ block: 'nearest' });
      }
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (selectedIndex > 0) {
        selectedIndex--;
        updateSelection();
        const selectedEl = resultsContainer?.children[selectedIndex] as HTMLElement;
        if (selectedEl) selectedEl.scrollIntoView({ block: 'nearest' });
      }
    } else if (e.key === 'Enter') {
      e.preventDefault();
      executeItem(selectedIndex);
    }
  });
</script>