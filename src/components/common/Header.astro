---
import ThemeIcon from './ThemeIcon.astro';
import SiteSearch from './SiteSearch.astro';
import LanguageToggle from './LanguageToggle.astro';
import { Search } from '@lucide/astro';
---

<!-- Floating Magnetic Command Pill -->
<div class="fixed top-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-2 group">
  <button 
    id="magnetic-pill"
    class="search-trigger flex items-center gap-3 px-6 py-2.5 rounded-full border border-border bg-background/40 backdrop-blur-md text-sm font-mono text-muted-foreground hover:text-foreground hover:bg-background/60 hover:border-primary/50 transition-all shadow-lg"
    aria-label="Initialize Search"
    aria-haspopup="dialog"
  >
    <Search size={16} class="text-primary" />
    <span>[ ⌘K / Ctrl+K ] 唤醒搜索</span>
  </button>
  
  <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
    <LanguageToggle />
    <ThemeIcon />
  </div>
</div>

<!-- Global Site Search Modal -->
<SiteSearch />

<script>
  // Magnetic Effect
  const pill = document.getElementById('magnetic-pill');
  if (pill) {
    document.addEventListener('mousemove', (e) => {
      const rect = pill.getBoundingClientRect();
      // Original position is implicitly centered because of parent, but the pill itself is static in the flex container
      // For accurate magnetic effect without layout jitter, we translate the pill itself.
      // Wait, we need to be careful with offset calculation.
      const x = rect.left + rect.width / 2;
      const y = rect.top + rect.height / 2;
      const distance = Math.sqrt(Math.pow(e.clientX - x, 2) + Math.pow(e.clientY - y, 2));
      
      if (distance < 120) { 
        const pullX = (e.clientX - x) * 0.15;
        const pullY = (e.clientY - y) * 0.15;
        pill.style.transform = `translate(${pullX}px, ${pullY}px)`;
      } else {
        pill.style.transform = `translate(0px, 0px)`;
      }
    });
  }
</script>
