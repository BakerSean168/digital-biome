---
import { getBookmarksByCategory } from '../../utils/notes';
import BookmarkCategory from './BookmarkCategory.astro';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const bookmarksByCategory = await getBookmarksByCategory();
const hasBookmarks = bookmarksByCategory.size > 0;
---

<div class:list={['relative z-10 w-full', compact ? 'pb-0' : 'pb-20']}>
  {hasBookmarks
    ? Array.from(bookmarksByCategory.entries()).map(([category, bookmarks]) => (
        <BookmarkCategory name={category} bookmarks={bookmarks} />
      ))
    : (
      <div class="text-center py-12 text-muted-foreground">
        <p class="mb-2">还没有书签</p>
        <p class="text-sm">在笔记中添加 <code class="bg-card-hover px-1.5 py-0.5 rounded text-xs">url</code> 字段以及 <code class="bg-card-hover px-1.5 py-0.5 rounded text-xs">website</code>、<code class="bg-card-hover px-1.5 py-0.5 rounded text-xs">resource</code> 和资源类型标签即可在此显示</p>
      </div>
    )
  }
</div>
