---
import { Link, Play } from '@lucide/astro';
import type { Bookmark } from '../../types/notes';

interface Props {
  name: string;
  bookmarks: Bookmark[];
}

const { name, bookmarks } = Astro.props;
---

<div class="mb-10 w-full">
  <div class="flex items-center justify-between mb-6">
    <h3 class="text-xl font-semibold text-foreground tracking-wide flex items-center gap-2">
      {name}
    </h3>
    <div class="px-3 py-1 bg-primary/10 text-primary text-sm rounded-full font-medium">
      {bookmarks.length} 个资源
    </div>
  </div>
  
  <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-x-4 gap-y-6">
    {bookmarks.map((bookmark) => {
      let domain = "example.com";
      try {
        domain = new URL(bookmark.url).hostname;
      } catch (e) {
        // keep fallback domain
      }
      const iconUrl = `https://www.google.com/s2/favicons?domain=${domain}&sz=128`;

      return (
        <a
          href={bookmark.url}
          class="group flex flex-col items-center gap-3 transition-all duration-300"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="w-16 h-16 rounded-2xl bg-card border border-border flex items-center justify-center text-foreground group-hover:border-primary/50 group-hover:bg-primary/5 transition-all duration-300 shadow-sm group-hover:shadow-md">
            {bookmark.icon
              ? <Fragment set:html={bookmark.icon} />
              : <img
                  src={iconUrl}
                  alt={`${bookmark.title} favicon`}
                  class="w-7 h-7 object-contain transition-transform duration-300 group-hover:scale-110"
                  loading="lazy"
                />
            }
          </div>
          <div class="flex flex-col items-center w-full px-1">
            <span class="text-sm font-medium text-foreground text-center truncate w-full group-hover:text-primary transition-colors">{bookmark.title}</span>
            {bookmark.description && (
              <span class="text-xs text-muted-foreground text-center truncate w-full mt-0.5">{bookmark.description}</span>
            )}
          </div>
        </a>
      );
    })}
  </div>
</div>
