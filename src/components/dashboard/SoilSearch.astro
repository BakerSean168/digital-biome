---
/**
 * 土壤智能搜索框组件 (SoilSearch)
 * 埋在数字土壤中，作为整棵数字生态树的根基。
 * 支持快捷命令：
 *   tr <text>  → Google 翻译
 *   g <query>  → Google 搜索
 *   gh <query> → GitHub 搜索
 *   n <query>  → 站内笔记搜索
 *   a <query>  → 站内资产搜索
 *   直接输入   → 跳转默认站内 Pagefind 检索 (/discover)
 */
import { Search, CornerDownLeft } from '@lucide/astro';

interface Props {
  placeholder?: string;
  defaultEngine?: 'google' | 'bing' | 'duckduckgo';
  discoverPath?: string;
}

const { 
  placeholder = "搜索笔记、项目、电影、游戏、音乐，或键入 gh/tr 指令...", 
  defaultEngine = 'google',
  discoverPath = '/discover',
} = Astro.props;
---

<div class="relative w-full max-w-3xl mx-auto z-30 mt-[-80px] px-4">
  <!-- 土壤放射发光阴影层 -->
  <div class="absolute inset-x-0 -top-24 -bottom-10 bg-gradient-to-t from-bg-deep via-bg-deep/85 to-transparent blur-2xl pointer-events-none -z-10"></div>
  <div class="absolute inset-x-12 -top-12 bottom-0 bg-primary/4 blur-3xl rounded-full pointer-events-none -z-10"></div>
  <div class="absolute inset-x-24 -top-8 bottom-4 bg-cyan-500/4 blur-3xl rounded-full pointer-events-none -z-10"></div>

  <!-- 搜索框容器 -->
  <div id="search-wrapper" class="relative flex items-center bg-bg-panel/40 backdrop-blur-xl border border-border-soft hover:border-primary/40 focus-within:border-primary/70 focus-within:ring-1 focus-within:ring-primary/20 rounded-full px-5 py-4 shadow-[0_20px_50px_rgba(0,0,0,0.6)] transition-all duration-300 group">
    
    <!-- 放大镜图标 & 闪烁点 -->
    <div class="flex items-center pl-1 mr-3 relative">
      <Search class="text-text-muted group-focus-within:text-primary transition-colors duration-300" size={20} />
      <span class="absolute -top-1 -right-1 w-2 h-2 rounded-full bg-primary animate-ping opacity-0 group-focus-within:opacity-100 transition-opacity duration-300"></span>
      <span class="absolute -top-1 -right-1 w-2 h-2 rounded-full bg-primary opacity-0 group-focus-within:opacity-100 transition-opacity duration-300"></span>
    </div>

    <!-- 输入框 -->
    <input 
      type="text" 
      id="smart-search" 
      placeholder={placeholder}
      aria-label="Soil Search"
      autocomplete="off"
      data-engine={defaultEngine}
      data-discover-path={discoverPath}
      class="w-full bg-transparent border-none outline-none text-text-main placeholder:text-text-muted/50 text-sm font-mono tracking-wide"
    />

    <!-- 回车图标 -->
    <div class="flex items-center gap-1.5 ml-2">
      <kbd class="hidden md:inline-flex items-center gap-0.5 px-2 py-1 text-[10px] font-mono bg-bg-deep/60 text-text-muted border border-border-soft rounded-lg">
        Enter <CornerDownLeft size={10} />
      </kbd>
    </div>
  </div>

  <!-- 智能快捷指令浮现框 -->
  <div class="absolute left-0 right-0 top-full mt-3 flex flex-wrap justify-center gap-4 opacity-0 -translate-y-2 pointer-events-none transition-all duration-300 z-40" id="search-hints">
    <span class="text-[11px] font-mono text-text-muted flex items-center gap-1">
      <kbd class="bg-bg-panel px-1.5 py-0.5 rounded border border-border-soft text-primary font-bold">tr</kbd> 翻译
    </span>
    <span class="text-[11px] font-mono text-text-muted flex items-center gap-1">
      <kbd class="bg-bg-panel px-1.5 py-0.5 rounded border border-border-soft text-primary font-bold">g</kbd> Google
    </span>
    <span class="text-[11px] font-mono text-text-muted flex items-center gap-1">
      <kbd class="bg-bg-panel px-1.5 py-0.5 rounded border border-border-soft text-primary font-bold">gh</kbd> GitHub
    </span>
    <span class="text-[11px] font-mono text-text-muted flex items-center gap-1">
      <kbd class="bg-bg-panel px-1.5 py-0.5 rounded border border-border-soft text-primary font-bold">n</kbd> 站内笔记
    </span>
    <span class="text-[11px] font-mono text-text-muted flex items-center gap-1">
      <kbd class="bg-bg-panel px-1.5 py-0.5 rounded border border-border-soft text-primary font-bold">a</kbd> 站内资产
    </span>
  </div>
</div>

<script>
  const searchInput = document.getElementById('smart-search') as HTMLInputElement;
  const hints = document.getElementById('search-hints');
  const searchWrapper = document.getElementById('search-wrapper');
  
  const COMMANDS: Record<string, (query: string) => string> = {
    'tr': (q) => `https://translate.google.com/?sl=auto&tl=zh-CN&text=${encodeURIComponent(q)}`,
    'g': (q) => `https://www.google.com/search?q=${encodeURIComponent(q)}`,
    'gh': (q) => `https://github.com/search?q=${encodeURIComponent(q)}`,
    'b': (q) => `https://www.bing.com/search?q=${encodeURIComponent(q)}`,
    'n': (q) => `${searchInput.dataset.discoverPath || '/discover'}?scope=notes&q=${encodeURIComponent(q)}`,
    'a': (q) => `${searchInput.dataset.discoverPath || '/discover'}?scope=assets&q=${encodeURIComponent(q)}`,
    'yt': (q) => `https://www.youtube.com/results?search_query=${encodeURIComponent(q)}`,
  };

  const COMMAND_COLORS: Record<string, string> = {
    'gh': 'border-emerald-500/70 shadow-[0_0_20px_rgba(16,185,129,0.3)]',
    'tr': 'border-sky-500/70 shadow-[0_0_20px_rgba(56,189,248,0.3)]',
    'n': 'border-cyan-500/70 shadow-[0_0_20px_rgba(6,182,212,0.3)]',
    'a': 'border-fuchsia-500/70 shadow-[0_0_20px_rgba(217,70,239,0.3)]',
    'g': 'border-blue-500/70 shadow-[0_0_20px_rgba(59,130,246,0.3)]',
    'yt': 'border-red-500/70 shadow-[0_0_20px_rgba(239,68,68,0.3)]',
  };

  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const value = searchInput.value.trim();
      if (!value) return;

      const parts = value.split(' ');
      const cmd = parts[0].toLowerCase();
      const query = parts.slice(1).join(' ');

      let url: string;
      if (COMMANDS[cmd] && query) {
        url = COMMANDS[cmd](query);
      } else {
        const internalPath = searchInput.dataset.discoverPath || '/discover';
        url = `${internalPath}?q=${encodeURIComponent(value)}`;
      }

      if (url.startsWith('/')) {
        window.location.href = url;
      } else {
        window.open(url, '_blank');
      }
      searchInput.value = '';
      
      // Reset color classes on submit
      if (searchWrapper) {
        Object.values(COMMAND_COLORS).forEach(cls => {
          cls.split(' ').forEach(c => searchWrapper.classList.remove(c));
        });
      }
    }
  });

  searchInput?.addEventListener('input', () => {
    const value = searchInput.value.trim();
    const parts = value.split(' ');
    const firstWord = parts[0].toLowerCase();

    if (searchWrapper) {
      // Remove all dynamic classes
      Object.values(COMMAND_COLORS).forEach(cls => {
        cls.split(' ').forEach(c => searchWrapper.classList.remove(c));
      });

      // Add corresponding classes if matching command with space
      if (COMMAND_COLORS[firstWord] && parts.length > 1) {
        COMMAND_COLORS[firstWord].split(' ').forEach(c => searchWrapper.classList.add(c));
      }
    }
  });

  searchInput?.addEventListener('focus', () => {
    hints?.classList.remove('opacity-0', '-translate-y-2', 'pointer-events-none');
    hints?.classList.add('opacity-100', 'translate-y-0');
  });

  searchInput?.addEventListener('blur', () => {
    setTimeout(() => {
      hints?.classList.add('opacity-0', '-translate-y-2', 'pointer-events-none');
      hints?.classList.remove('opacity-100', 'translate-y-0');
    }, 200);
  });

  // 自动聚焦
  if (window.innerWidth > 768) {
    searchInput?.focus();
  }
</script>
