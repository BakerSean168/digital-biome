<script>
  // 悬停与触控交互控制 JS 逻辑
  const fruitNodes = document.querySelectorAll('.fruit-node');
  const detailCards = document.querySelectorAll('.detail-card');
  const drawer = document.getElementById('mobile-drawer');
  const drawerContent = document.getElementById('mobile-drawer-content');
  const backdrop = document.getElementById('mobile-drawer-backdrop');
  const closeHandle = document.getElementById('mobile-drawer-close-handle');

  // 显示指定卡片 (Desktop only)
  function showCard(targetId: string) {
    if (window.innerWidth < 768) return;
    detailCards.forEach(c => {
      if (c.id !== targetId) {
        c.classList.add('hidden');
      }
    });
    const card = document.getElementById(targetId);
    if (card) {
      card.classList.remove('hidden');
    }

    // Toggle HUD Connector Lines
    document.querySelectorAll('.hud-connector-line').forEach(l => {
      l.classList.remove('opacity-100');
      l.classList.add('opacity-0');
    });
    const line = document.getElementById(`line-${targetId}`);
    if (line) {
      line.classList.remove('opacity-0');
      line.classList.add('opacity-100');
    }

    // Container visual focus highlight
    const container = document.querySelector('.fruit-node')?.closest('.relative');
    if (container) {
      container.classList.add('has-active-node');
    }
    fruitNodes.forEach(node => {
      if (node.getAttribute('data-target') === targetId) {
        node.classList.add('active-hover');
        node.setAttribute('aria-expanded', 'true');
      } else {
        node.classList.remove('active-hover');
        node.setAttribute('aria-expanded', 'false');
      }
    });
  }

  // 隐藏所有卡片 (Desktop only)
  function hideAllCards() {
    detailCards.forEach(c => c.classList.add('hidden'));

    // Reset HUD Lines
    document.querySelectorAll('.hud-connector-line').forEach(l => {
      l.classList.remove('opacity-100');
      l.classList.add('opacity-0');
    });

    // Reset container and node highlight states
    const container = document.querySelector('.fruit-node')?.closest('.relative');
    if (container) {
      container.classList.remove('has-active-node');
    }
    fruitNodes.forEach(node => {
      node.classList.remove('active-hover');
      node.setAttribute('aria-expanded', 'false');
    });
  }

  // Mobile Drawer 控制
  function openMobileDrawer(targetId: string) {
    const card = document.getElementById(targetId);
    if (card && drawer && drawerContent && backdrop) {
      drawerContent.innerHTML = card.innerHTML;
      drawer.classList.remove('translate-y-full');
      backdrop.classList.remove('pointer-events-none', 'opacity-0');
      backdrop.classList.add('opacity-100');
      document.body.style.overflow = 'hidden'; // 阻止背景滚动
    }
  }

  // Close Mobile Drawer
  function closeMobileDrawer() {
    if (drawer && backdrop) {
      drawer.classList.add('translate-y-full');
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
    }
  }

  fruitNodes.forEach(node => {
    const targetId = node.getAttribute('data-target');
    if (!targetId) return;

    // Click/Touch 点击事件
    node.addEventListener('click', (e) => {
      if (window.innerWidth < 768) {
        e.preventDefault();
        e.stopPropagation();
        openMobileDrawer(targetId);
      } else {
        showCard(targetId);
      }
    });

    // Hover 悬停事件
    node.addEventListener('mouseenter', () => {
      showCard(targetId);
    });

    // Hover 移出事件 (带有小延迟，让用户可以把鼠标移进卡片内部进行点击)
    node.addEventListener('mouseleave', (e) => {
      const mouseEvent = e as MouseEvent;
      const toElement = mouseEvent.relatedTarget as HTMLElement;
      if (toElement && toElement.closest('.detail-card')) return;
      
      // 延迟微秒隐藏，给鼠标留出移动到 Popover 的缓冲时间
      setTimeout(() => {
        const activeHover = document.querySelector('.fruit-node:hover');
        const activeCardHover = document.querySelector('.detail-card:hover');
        if (!activeHover && !activeCardHover) {
          hideAllCards();
        }
      }, 100);
    });

    // Keyboard 键盘无障碍支持
    node.addEventListener('keydown', (e) => {
      const kbEvent = e as KeyboardEvent;
      if (kbEvent.key === 'Enter' || kbEvent.key === ' ') {
        kbEvent.preventDefault();
        if (window.innerWidth < 768) {
          openMobileDrawer(targetId);
        } else {
          showCard(targetId);
        }
      }
    });
  });

  // 卡片内部的鼠标事件监听
  detailCards.forEach(card => {
    card.addEventListener('mouseleave', (e) => {
      const mouseEvent = e as MouseEvent;
      const toElement = mouseEvent.relatedTarget as HTMLElement;
      if (toElement && toElement.closest('.fruit-node')) return;
      hideAllCards();
    });
  });

  // Drawer 关闭点击事件
  backdrop?.addEventListener('click', closeMobileDrawer);
  closeHandle?.addEventListener('click', closeMobileDrawer);
</script>

