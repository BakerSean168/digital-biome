---
/**
 * 数字化生态树组件 (BiomeTree)
 * 基于 1:1 坐标轴对齐的高保真赛博生态树组件，
 * 将 CSS Screen 混合底图与 SVG 嵌套式交互果实相结合。
 */
import { Book, Code, Gamepad2, User, Sparkles } from '@lucide/astro';
import { getNewCreatedNotes, getRecentNotesWithDate, getPublicNotesCount } from '../../utils/notes';
import { buildKnowledgeNoteHref } from '../../domain/note-routing';

// 动态获取真实 Obsidian 笔记总数
let notesCount = 1042;
let newLeaves: any[] = [];
let oldLeaves: any[] = [];

try {
  const count = getPublicNotesCount();
  if (count > 0) {
    notesCount = count;
  }

  // 获取最新创建的 4 篇笔记 (新叶)
  const newCreated = getNewCreatedNotes(4);
  const newCreatedIds = new Set(newCreated.map(n => n.id));

  // 获取最近更新的 2 篇笔记 (老叶) - 排除已在最新创建中的笔记以避免重复
  const allRecentWithDate = await getRecentNotesWithDate(10);
  const recentUpdatedWithDate = allRecentWithDate
    .filter(item => !newCreatedIds.has(item.note.id))
    .slice(0, 2);

  // Helper to calculate characters / word count
  const getWordCount = (body: string = ''): number => {
    const cleaned = body.replace(/[#*`~_\-[\]()|]/g, '').trim();
    const cnChar = (cleaned.match(/[\u4e00-\u9fa5]/g) || []).length;
    const enWords = cleaned.replace(/[\u4e00-\u9fa5]/g, ' ').split(/\s+/).filter(Boolean).length;
    return cnChar + enWords;
  };

  // Helper to format date as "M月D日"
  const formatMonthDay = (dateInput: any): string => {
    if (!dateInput) return '';
    const date = typeof dateInput === 'string' ? new Date(dateInput) : dateInput;
    if (isNaN(date.getTime())) return '';
    return `${date.getMonth() + 1}月${date.getDate()}日`;
  };

  // Helper to get first tag display name
  const getFirstTag = (tags?: string[] | null): string => {
    if (!tags || tags.length === 0) return 'Note';
    const first = tags[0];
    return first.includes('/') ? first.split('/').pop() || 'Note' : first;
  };

  newLeaves = newCreated.map(note => ({
    title: note.title || note.id.split('/').pop() || '',
    description: note.description || '暂无描述 // NO_DESCRIPTION',
    tag: getFirstTag(note.tags),
    dateText: `${formatMonthDay(note.created)} 创建`,
    words: '500 字',
    href: buildKnowledgeNoteHref(note.id)
  }));

  oldLeaves = recentUpdatedWithDate.map(item => ({
    title: item.note.data.title || item.note.id.split('/').pop() || '',
    description: item.note.data.description || '暂无描述 // NO_DESCRIPTION',
    tag: getFirstTag(item.note.data.tags),
    dateText: `${formatMonthDay(item.date)} 更新`,
    words: `${getWordCount(item.note.body)} 字`,
    href: buildKnowledgeNoteHref(item.note.id)
  }));
} catch (e) {
  console.warn("Failed to load notes count or dynamic leaves: ", e);
}
---

<div class="relative w-full max-w-4xl mx-auto aspect-square overflow-visible flex items-center justify-center select-none mt-4 md:mt-6 px-4">
  
  <!-- 0. 大树底图图层 (Layer 2) - 使用 screen 滤色模式过滤黑色背景，渲染出无瑕疵的亮部发光 -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-0">
    <img 
      src="/assets/images/organic_biome_tree_transparent.webp" 
      alt="Ecosystem Tree Base" 
      class="w-[85%] h-[85%] object-contain"
      style="opacity: var(--tree-opacity, 0.85); filter: var(--tree-shadow, drop-shadow(0px 0px 40px rgba(0, 255, 144, 0.15)));"
    />
  </div>

  <!-- 1. 生态树 SVG 动态矢量图层 (Layer 3) -->
  <svg viewBox="0 0 800 800" class="absolute inset-0 w-full h-full overflow-visible z-10" fill="none" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <!-- 高保真霓虹发光滤镜 -->
      <filter id="neon-glow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="6" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <!-- 图层 B: HUD 动态连接线 -->
    <g class="hud-lines">
      <!-- MIND connector line -->
      <path id="line-notes-card" d="M385,178 L385,130" stroke="var(--color-branch-mind)" stroke-width="1.5" class="hud-connector-line opacity-0 transition-opacity duration-300" filter="url(#neon-glow)" />

      <!-- DEV connector line -->
      <path id="line-builds-card" d="M230,305 L100,305" stroke="var(--color-branch-dev)" stroke-width="1.5" class="hud-connector-line opacity-0 transition-opacity duration-300" filter="url(#neon-glow)" />

      <!-- LIFE connector line -->
      <path id="line-life-card" d="M585,305 L700,305" stroke="var(--color-branch-life)" stroke-width="1.5" class="hud-connector-line opacity-0 transition-opacity duration-300" filter="url(#neon-glow)" />

      <!-- LAB connector line -->
      <path id="line-lab-card" d="M162,450 L80,450" stroke="var(--color-branch-lab)" stroke-width="1.5" class="hud-connector-line opacity-0 transition-opacity duration-300" filter="url(#neon-glow)" />

      <!-- ABOUT connector line -->
      <path id="line-about-card" d="M598,475 L720,475" stroke="var(--color-branch-about)" stroke-width="1.5" class="hud-connector-line opacity-0 transition-opacity duration-300" filter="url(#neon-glow)" />
    </g>

    <!-- Biome note leaf connection lines -->
    <g class="hud-lines hidden xl:block">
      <!-- Line 1: Left Top -->
      <path class="hud-line-1" d="M330,210 L140,112 L-24,112" stroke="rgba(139, 154, 70, 0.22)" stroke-width="1.2" filter="url(#neon-glow)" style="transition: stroke 0.3s, stroke-width 0.3s, opacity 0.3s;" />
      <!-- Line 2: Left Middle -->
      <path class="hud-line-2" d="M240,310 L120,368 L-24,368" stroke="rgba(139, 154, 70, 0.22)" stroke-width="1.2" filter="url(#neon-glow)" style="transition: stroke 0.3s, stroke-width 0.3s, opacity 0.3s;" />
      <!-- Line 3: Left Bottom -->
      <path class="hud-line-3" d="M320,560 L180,624 L-24,624" stroke="rgba(245, 158, 11, 0.22)" stroke-width="1.2" filter="url(#neon-glow)" style="transition: stroke 0.3s, stroke-width 0.3s, opacity 0.3s;" />
      <!-- Line 4: Right Top -->
      <path class="hud-line-4" d="M470,210 L660,112 L824,112" stroke="rgba(139, 154, 70, 0.22)" stroke-width="1.2" filter="url(#neon-glow)" style="transition: stroke 0.3s, stroke-width 0.3s, opacity 0.3s;" />
      <!-- Line 5: Right Middle -->
      <path class="hud-line-5" d="M560,310 L680,368 L824,368" stroke="rgba(139, 154, 70, 0.22)" stroke-width="1.2" filter="url(#neon-glow)" style="transition: stroke 0.3s, stroke-width 0.3s, opacity 0.3s;" />
      <!-- Line 6: Right Bottom -->
      <path class="hud-line-6" d="M490,550 L620,624 L824,624" stroke="rgba(245, 158, 11, 0.22)" stroke-width="1.2" filter="url(#neon-glow)" style="transition: stroke 0.3s, stroke-width 0.3s, opacity 0.3s;" />
    </g>

    <!-- 图层 C: 交互果实节点 (Fruit Nodes - 发光呼吸徽章，嵌套结构防止 CSS transform 冲掉位移) -->
    
    <!-- 节点 1: MIND 思维之枝 (树冠中心偏上) -->
    <g transform="translate(385, 200)">
      <g class="fruit-node group cursor-pointer biome-branch-sway" data-target="notes-card" tabindex="0" role="button" aria-haspopup="true" aria-expanded="false" aria-label="MIND 思维之枝">
        <circle cx="0" cy="0" r="22" fill="var(--bg-circle-node, #070a13)" stroke="var(--color-branch-mind)" stroke-width="2.5" filter="url(#neon-glow)" class="animate-pulse-soft"/>
        <circle cx="0" cy="0" r="2" fill="var(--color-branch-mind)" filter="url(#neon-glow)"/>
        <text x="0" y="4" text-anchor="middle" font-size="12" class="select-none">📓</text>
        <text x="0" y="-32" text-anchor="middle" class="fill-foreground font-mono text-[9px] font-bold tracking-[0.2em] opacity-80 group-hover:opacity-100 group-hover:fill-branch-mind transition-all duration-300">MIND</text>
      </g>
    </g>

    <!-- 节点 2: DEV 创造之枝 (左侧粗枝末端) -->
    <g transform="translate(250, 305)">
      <g class="fruit-node group cursor-pointer biome-branch-sway-delayed" data-target="builds-card" tabindex="0" role="button" aria-haspopup="true" aria-expanded="false" aria-label="DEV 创造之枝">
        <circle cx="0" cy="0" r="20" fill="var(--bg-circle-node, #070a13)" stroke="var(--color-branch-dev)" stroke-width="2" filter="url(#neon-glow)" class="animate-pulse-soft"/>
        <circle cx="0" cy="0" r="2" fill="var(--color-branch-dev)" filter="url(#neon-glow)"/>
        <text x="0" y="4" text-anchor="middle" font-size="11" class="select-none">💻</text>
        <text x="0" y="32" text-anchor="middle" class="fill-foreground font-mono text-[9px] font-bold tracking-[0.2em] opacity-80 group-hover:opacity-100 group-hover:fill-branch-dev transition-all duration-300">DEV</text>
      </g>
    </g>

    <!-- 节点 3: LIFE 生活与游戏之果 (右侧粗枝末端) -->
    <g transform="translate(565, 305)">
      <g class="fruit-node group cursor-pointer biome-branch-sway" data-target="life-card" tabindex="0" role="button" aria-haspopup="true" aria-expanded="false" aria-label="LIFE 生活与体验之果">
        <circle cx="0" cy="0" r="20" fill="var(--bg-circle-node, #070a13)" stroke="var(--color-branch-life)" stroke-width="2" filter="url(#neon-glow)" class="animate-pulse-soft"/>
        <circle cx="0" cy="0" r="2" fill="var(--color-branch-life)" filter="url(#neon-glow)"/>
        <text x="0" y="4" text-anchor="middle" font-size="11" class="select-none">🎮</text>
        <text x="0" y="32" text-anchor="middle" class="fill-foreground font-mono text-[9px] font-bold tracking-[0.2em] opacity-80 group-hover:opacity-100 group-hover:fill-branch-life transition-all duration-300">LIFE</text>
      </g>
    </g>

    <!-- 节点 4: LAB 极客之叶 (开发左侧细分枝梢) -->
    <g transform="translate(180, 450)">
      <g class="fruit-node group cursor-pointer biome-branch-sway-delayed" data-target="lab-card" tabindex="0" role="button" aria-haspopup="true" aria-expanded="false" aria-label="LAB 极客实验室之叶">
        <circle cx="0" cy="0" r="18" fill="var(--bg-circle-node, #070a13)" stroke="var(--color-branch-lab)" stroke-width="2" filter="url(#neon-glow)" class="animate-pulse-soft"/>
        <circle cx="0" cy="0" r="2" fill="var(--color-branch-lab)" filter="url(#neon-glow)"/>
        <text x="0" y="3.5" text-anchor="middle" font-size="9" class="select-none">⚙️</text>
        <text x="0" y="30" text-anchor="middle" class="fill-foreground font-mono text-[8px] font-bold tracking-widest opacity-80 group-hover:opacity-100 group-hover:fill-branch-lab transition-colors duration-300">LAB</text>
      </g>
    </g>

    <!-- 节点 5: ABOUT 宿主轮廓 (生活右侧细分枝梢) -->
    <g transform="translate(580, 475)">
      <g class="fruit-node group cursor-pointer biome-branch-sway" data-target="about-card" tabindex="0" role="button" aria-haspopup="true" aria-expanded="false" aria-label="ABOUT 宿主轮廓">
        <circle cx="0" cy="0" r="18" fill="var(--bg-circle-node, #070a13)" stroke="var(--color-branch-about)" stroke-width="2" filter="url(#neon-glow)" class="animate-pulse-soft"/>
        <circle cx="0" cy="0" r="2" fill="var(--color-branch-about)" filter="url(#neon-glow)"/>
        <text x="0" y="3.5" text-anchor="middle" font-size="9" class="select-none">👤</text>
        <text x="0" y="30" text-anchor="middle" class="fill-foreground font-mono text-[8px] font-bold tracking-widest opacity-80 group-hover:opacity-100 group-hover:fill-branch-about transition-colors duration-300">ABOUT</text>
      </g>
    </g>
  </svg>

  <!-- 图层 D: 悬浮详情卡片 (DOM Overlays - 绝对定位，完美配合 1:1 树体结构) -->

  <!-- CARD 1: MIND 思维之枝 -->
  <div id="notes-card" class="detail-card absolute hidden top-[10%] left-[50%] -translate-x-1/2 bg-card/85 backdrop-blur-xl border border-border-soft p-5 rounded-2xl shadow-[0_24px_50px_rgba(0,0,0,0.6)] w-80 md:w-88 z-30 transition-all duration-300">
    <div class="absolute -top-px left-10 right-10 h-px bg-gradient-to-r from-transparent via-branch-mind to-transparent"></div>
    <div class="flex items-center gap-2 mb-3">
      <Book class="text-branch-mind" size={18} />
      <h4 class="text-sm font-bold font-mono text-foreground">MIND / 思维之枝</h4>
    </div>
    <p class="text-[11px] text-muted-foreground leading-relaxed mb-4">
      记录我的知识体系与日常思考。已累计灌溉了 <strong class="text-branch-mind font-mono font-bold text-sm">{notesCount}</strong> 篇 Obsidian 沉淀笔记。
    </p>
    <div class="flex flex-wrap gap-1.5 mb-4">
      <span class="px-2 py-0.5 text-[9px] font-mono rounded bg-branch-mind/10 border border-branch-mind/20 text-branch-mind">笔记沉淀</span>
      <span class="px-2 py-0.5 text-[9px] font-mono rounded bg-branch-mind/10 border border-branch-mind/20 text-branch-mind">知识森林</span>
      <span class="px-2 py-0.5 text-[9px] font-mono rounded bg-branch-mind/10 border border-branch-mind/20 text-branch-mind">心智地图</span>
    </div>
    <div class="pt-3 border-t border-border-soft flex justify-between items-center text-[10px] font-mono">
      <span class="text-muted-foreground">同步工作流：Obsidian Linter</span>
      <a href="/notes" class="text-branch-mind hover:underline flex items-center gap-0.5">进入知识库 →</a>
    </div>
  </div>

  <!-- CARD 2: DEV 创造之枝 -->
  <div id="builds-card" class="detail-card absolute hidden top-[28%] left-[1%] md:left-[4%] bg-card/85 backdrop-blur-xl border border-border-soft p-5 rounded-2xl shadow-[0_24px_50px_rgba(0,0,0,0.6)] w-80 md:w-88 z-30 transition-all duration-300">
    <div class="absolute -top-px left-10 right-10 h-px bg-gradient-to-r from-transparent via-branch-dev to-transparent"></div>
    <div class="flex items-center gap-2 mb-3">
      <Code class="text-branch-dev" size={18} />
      <h4 class="text-sm font-bold font-mono text-foreground">DEV / 创造之枝</h4>
    </div>
    <p class="text-[11px] text-muted-foreground leading-relaxed mb-4">
      工程切片与架构推演。存放高性能工程底座及全栈系统构建记录。
    </p>
    <div class="flex flex-wrap gap-1.5 mb-4">
      <span class="px-2 py-0.5 text-[9px] font-mono rounded bg-branch-dev/10 border border-branch-dev/20 text-branch-dev">Vue3 & React</span>
      <span class="px-2 py-0.5 text-[9px] font-mono rounded bg-branch-dev/10 border border-branch-dev/20 text-branch-dev">Prisma 全栈</span>
      <span class="px-2 py-0.5 text-[9px] font-mono rounded bg-branch-dev/10 border border-branch-dev/20 text-branch-dev">工程攻坚</span>
    </div>
    <div class="pt-3 border-t border-border-soft flex justify-between items-center text-[10px] font-mono">
      <span class="text-muted-foreground">开发状态：Vibe Coding</span>
      <a href="/dev" class="text-branch-dev hover:underline flex items-center gap-0.5">代表项目 →</a>
    </div>
  </div>

  <!-- CARD 3: LIFE 生活之枝 -->
  <div id="life-card" class="detail-card absolute hidden top-[28%] right-[1%] md:right-[4%] bg-card/85 backdrop-blur-xl border border-border-soft p-5 rounded-2xl shadow-[0_24px_50px_rgba(0,0,0,0.6)] w-80 md:w-88 z-30 transition-all duration-300">
    <div class="absolute -top-px left-10 right-10 h-px bg-gradient-to-r from-transparent via-branch-life to-transparent"></div>
    <div class="flex items-center gap-2 mb-3">
      <Gamepad2 class="text-branch-life" size={18} />
      <h4 class="text-sm font-bold font-mono text-foreground">LIFE / 生命与体验</h4>
    </div>
    <p class="text-[11px] text-muted-foreground leading-relaxed mb-4">
      代码之外的碳基体验采样。不仅是游戏记录，更是对光影、声场与数字生活叙事的颗粒度记录。
    </p>
    <div class="flex flex-wrap gap-1.5 mb-4">
      <span class="px-2 py-0.5 text-[9px] font-mono rounded bg-branch-life/10 border border-branch-life/20 text-branch-life">Steam 游玩</span>
      <span class="px-2 py-0.5 text-[9px] font-mono rounded bg-branch-life/10 border border-branch-life/20 text-branch-life">光影电影</span>
      <span class="px-2 py-0.5 text-[9px] font-mono rounded bg-branch-life/10 border border-branch-life/20 text-branch-life">春日歌单</span>
    </div>
    <div class="pt-3 border-t border-border-soft flex justify-between items-center text-[10px] font-mono">
      <span class="text-muted-foreground">状态：热爱可抵岁月漫长</span>
      <a href="/notes" class="text-branch-life hover:underline flex items-center gap-0.5">生活碎念 →</a>
    </div>
  </div>

  <!-- CARD 4: LAB 极客之叶 -->
  <div id="lab-card" class="detail-card absolute hidden top-[52%] left-[1%] md:left-[4%] bg-card/85 backdrop-blur-xl border border-border-soft p-5 rounded-2xl shadow-[0_24px_50px_rgba(0,0,0,0.6)] w-72 z-30 transition-all duration-300">
    <div class="absolute -top-px left-10 right-10 h-px bg-gradient-to-r from-transparent via-branch-lab to-transparent"></div>
    <div class="flex items-center gap-2 mb-2">
      <Sparkles class="text-branch-lab" size={16} />
      <h4 class="text-xs font-bold font-mono text-foreground">LAB / 极客实验室</h4>
    </div>
    <p class="text-[10px] text-muted-foreground leading-relaxed mb-3">
      承载整个生态运行的算力底座。涵盖公网控制面、边界路由与私有云容器编排。
    </p>
    <div class="pt-2 border-t border-border-soft flex justify-between items-center text-[10px] font-mono">
      <span class="text-muted-foreground">Uptime: 99.98%</span>
      <a href="/infrastructure" class="text-foreground hover:underline flex items-center gap-0.5">进入实验室 →</a>
    </div>
  </div>

  <!-- CARD 5: ABOUT 宿主年轮 -->
  <div id="about-card" class="detail-card absolute hidden top-[52%] right-[1%] md:right-[4%] bg-card/85 backdrop-blur-xl border border-border-soft p-5 rounded-2xl shadow-[0_24px_50px_rgba(0,0,0,0.6)] w-72 z-30 transition-all duration-300">
    <div class="absolute -top-px left-10 right-10 h-px bg-gradient-to-r from-transparent via-branch-about to-transparent"></div>
    <div class="flex items-center gap-2 mb-2">
      <User class="text-branch-about" size={16} />
      <h4 class="text-xs font-bold font-mono text-foreground">ABOUT / 宿主年轮</h4>
    </div>
    <p class="text-[10px] text-muted-foreground leading-relaxed mb-3">
      卢楼豪，专注于打磨像素级 UI/UX 体验的全栈独立开发者，崇尚优雅的逻辑与美学的共存。
    </p>
    <div class="pt-2 border-t border-border-soft flex justify-between items-center text-[10px] font-mono">
      <span class="text-muted-foreground">定位：数字手艺人</span>
      <a href="/about" class="text-foreground hover:underline flex items-center gap-0.5">关于我 →</a>
    </div>
  </div>

  <!-- HUD Floating Note Cards (New & Old Leaves) -->
  {newLeaves[0] && (
    <a href={newLeaves[0].href} class="hud-card-1 absolute hidden xl:flex flex-col justify-between top-[4%] left-[-28%] w-[24%] h-[20%] bg-card/45 backdrop-blur-md border border-border/40 hover:border-primary/50 hover:bg-card/75 p-4 rounded-xl shadow-lg transition-all duration-300 group hover:-translate-y-1 z-20">
      <div class="absolute -top-px left-4 right-4 h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
      <div class="flex items-center justify-between gap-2">
        <span class="px-1.5 py-0.5 text-[8px] font-mono rounded bg-primary/10 border border-primary/20 text-primary uppercase font-bold tracking-wider">🌱 {newLeaves[0].tag}</span>
        <span class="text-[8px] font-mono text-muted-foreground">{newLeaves[0].dateText}</span>
      </div>
      <h5 class="text-xs font-bold font-mono text-foreground line-clamp-1 group-hover:text-primary transition-colors mt-2">{newLeaves[0].title}</h5>
      <p class="text-[9px] text-muted-foreground leading-relaxed mt-1 line-clamp-2">{newLeaves[0].description}</p>
      <div class="mt-2 pt-1.5 border-t border-border/20 flex justify-between items-center text-[8px] font-mono text-muted-foreground/60">
        <span>{newLeaves[0].words}</span>
        <span class="group-hover:text-primary transition-colors">&gt; READ</span>
      </div>
    </a>
  )}

  {newLeaves[1] && (
    <a href={newLeaves[1].href} class="hud-card-2 absolute hidden xl:flex flex-col justify-between top-[36%] left-[-28%] w-[24%] h-[20%] bg-card/45 backdrop-blur-md border border-border/40 hover:border-primary/50 hover:bg-card/75 p-4 rounded-xl shadow-lg transition-all duration-300 group hover:-translate-y-1 z-20">
      <div class="absolute -top-px left-4 right-4 h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
      <div class="flex items-center justify-between gap-2">
        <span class="px-1.5 py-0.5 text-[8px] font-mono rounded bg-primary/10 border border-primary/20 text-primary uppercase font-bold tracking-wider">🌱 {newLeaves[1].tag}</span>
        <span class="text-[8px] font-mono text-muted-foreground">{newLeaves[1].dateText}</span>
