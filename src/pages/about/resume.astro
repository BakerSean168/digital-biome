---
// 简历页面
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_AUTHOR, SITE_NAME, AUTHOR_EMAIL, AUTHOR_PHONE, AUTHOR_LOCATION } from '../../constants';
import { Mail, Phone, MapPin, Printer, ArrowLeft } from '@lucide/astro';
---

<BaseLayout title={`Resume | ${SITE_NAME}`} description="我的专业简历">
  <main id="resume-wrapper" class="max-w-4xl mx-auto py-8 px-4 sm:px-6 lg:px-8 print:max-w-full print:p-0 print:bg-white">
    
    <!-- Header -->
    <div class="text-center pb-8 border-b-2 border-primary mb-8 print:border-black">
      <h1 class="text-4xl font-bold text-foreground mb-2 print:text-black">{SITE_AUTHOR}</h1>
      <p class="text-lg text-muted-foreground mb-4 print:text-gray-700">Web 开发者 | 终身学习者</p>
      <div class="flex flex-wrap justify-center gap-6 text-sm text-foreground print:text-black">
        <span class="flex items-center gap-1.5"><Mail size={16} class="text-primary print:text-black"/> {AUTHOR_EMAIL}</span>
        <span class="flex items-center gap-1.5"><Phone size={16} class="text-primary print:text-black"/> {AUTHOR_PHONE}</span>
        <span class="flex items-center gap-1.5"><MapPin size={16} class="text-primary print:text-black"/> {AUTHOR_LOCATION}</span>
      </div>
    </div>

    <div class="flex flex-col gap-10">
      
      <!-- Summary -->
      <section class="flex flex-col">
        <h2 class="text-xl font-bold text-primary border-b-2 border-border pb-2 mb-4 print:text-black print:border-black">个人总结</h2>
        <p class="text-foreground leading-relaxed print:text-black">
          经验丰富的 Web 开发者，精通现代 JavaScript 框架和全栈开发。
          致力于构建优雅、可扩展的解决方案并持续学习。
        </p>
      </section>

      <!-- Experience -->
      <section class="flex flex-col">
        <h2 class="text-xl font-bold text-primary border-b-2 border-border pb-2 mb-6 print:text-black print:border-black">工作经验</h2>
        
        <article class="mb-6 pl-4 border-l-2 border-border print:border-gray-300">
          <div class="flex flex-wrap justify-between items-baseline gap-4 mb-2">
            <h3 class="text-lg font-bold text-foreground print:text-black">高级开发者</h3>
            <span class="text-sm text-muted-foreground print:text-gray-600">2024 - 至今</span>
          </div>
          <p class="font-semibold text-primary mb-2 print:text-black">公司名称</p>
          <ul class="list-disc list-inside pl-4 text-foreground print:text-black space-y-1">
            <li>主导核心功能开发</li>
            <li>指导初级开发者</li>
            <li>提升 40% 性能</li>
          </ul>
        </article>

        <article class="mb-6 pl-4 border-l-2 border-border print:border-gray-300">
          <div class="flex flex-wrap justify-between items-baseline gap-4 mb-2">
            <h3 class="text-lg font-bold text-foreground print:text-black">全栈开发者</h3>
            <span class="text-sm text-muted-foreground print:text-gray-600">2022 - 2024</span>
          </div>
          <p class="font-semibold text-primary mb-2 print:text-black">前公司名称</p>
          <ul class="list-disc list-inside pl-4 text-foreground print:text-black space-y-1">
            <li>使用 React 和 Node.js 开发 Web 应用</li>
            <li>负责数据库设计和优化</li>
            <li>与设计和产品团队协作</li>
          </ul>
        </article>
      </section>

      <!-- Education -->
      <section class="flex flex-col">
        <h2 class="text-xl font-bold text-primary border-b-2 border-border pb-2 mb-6 print:text-black print:border-black">教育背景</h2>
        
        <article class="mb-6 pl-4 border-l-2 border-border print:border-gray-300">
          <div class="flex flex-wrap justify-between items-baseline gap-4 mb-2">
            <h3 class="text-lg font-bold text-foreground print:text-black">理学学士</h3>
            <span class="text-sm text-muted-foreground print:text-gray-600">2018 - 2022</span>
          </div>
          <p class="font-semibold text-primary mb-1 print:text-black">大学名称</p>
          <p class="text-foreground print:text-black">专业：计算机科学</p>
        </article>
      </section>

      <!-- Skills -->
      <section class="flex flex-col">
        <h2 class="text-xl font-bold text-primary border-b-2 border-border pb-2 mb-6 print:text-black print:border-black">专业技能</h2>
        
        <div class="flex flex-col gap-3">
          <div class="flex flex-col sm:flex-row gap-2 sm:gap-6 text-foreground print:text-black">
            <strong class="min-w-[120px] text-primary print:text-black">编程语言：</strong>
            <span>JavaScript, TypeScript, Python, SQL</span>
          </div>
          <div class="flex flex-col sm:flex-row gap-2 sm:gap-6 text-foreground print:text-black">
            <strong class="min-w-[120px] text-primary print:text-black">前端：</strong>
            <span>React, Vue.js, HTML5, CSS3, Tailwind</span>
          </div>
          <div class="flex flex-col sm:flex-row gap-2 sm:gap-6 text-foreground print:text-black">
            <strong class="min-w-[120px] text-primary print:text-black">后端：</strong>
            <span>Node.js, Express, PostgreSQL, MongoDB</span>
          </div>
          <div class="flex flex-col sm:flex-row gap-2 sm:gap-6 text-foreground print:text-black">
            <strong class="min-w-[120px] text-primary print:text-black">开发工具：</strong>
            <span>Git, Docker, CI/CD, AWS, VS Code</span>
          </div>
        </div>
      </section>

      <!-- Projects -->
      <section class="flex flex-col">
        <h2 class="text-xl font-bold text-primary border-b-2 border-border pb-2 mb-6 print:text-black print:border-black">项目经历</h2>
        
        <article class="mb-6 pl-4 border-l-2 border-border print:border-gray-300">
          <h3 class="text-lg font-bold text-foreground mb-1 print:text-black">{SITE_NAME} (个人网站)</h3>
          <p class="text-sm text-muted-foreground italic mb-2 print:text-gray-600">Astro • React • TypeScript</p>
          <p class="text-foreground print:text-black">使用 Astro 构建的个人作品集和知识分享平台。</p>
        </article>

        <article class="mb-6 pl-4 border-l-2 border-border print:border-gray-300">
          <h3 class="text-lg font-bold text-foreground mb-1 print:text-black">项目名称 2</h3>
          <p class="text-sm text-muted-foreground italic mb-2 print:text-gray-600">技术栈</p>
          <p class="text-foreground print:text-black">项目描述和核心成就。</p>
        </article>
      </section>

      <!-- Certifications -->
      <section class="flex flex-col">
        <h2 class="text-xl font-bold text-primary border-b-2 border-border pb-2 mb-6 print:text-black print:border-black">资格认证</h2>
        
        <ul class="list-disc list-inside pl-4 text-foreground print:text-black space-y-2">
          <li>认证名称 - 颁发机构 (年份)</li>
          <li>另一个认证 - 颁发机构 (年份)</li>
        </ul>
      </section>
    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mt-12 pt-8 border-t border-border print:hidden">
      <button onclick="window.print()" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary hover:bg-primary-hover text-white rounded-lg font-medium transition-colors">
        <Printer size={18} /> 打印 / 保存为 PDF
      </button>
      <a href="/about" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-transparent border-2 border-primary text-primary hover:bg-primary hover:text-white rounded-lg font-medium transition-colors">
        <ArrowLeft size={18} /> 返回关于
      </a>
    </div>
  </main>
</BaseLayout>

<style is:global>
  @media print {
    @page {
      margin: 0;
      size: A4 portrait;
    }

    body {
      margin: 1.5cm;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    body * {
      visibility: hidden;
    }

    #resume-wrapper, #resume-wrapper * {
      visibility: visible;
    }

    #resume-wrapper {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
    }

    header, footer {
      display: none !important;
    }
  }
</style>
