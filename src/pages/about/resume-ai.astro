---
// AI 应用前端简历
import ResumeHeader from '../../components/resume/ResumeHeader.astro';
import ResumePage from '../../components/resume/ResumePage.astro';
import ResumeSection from '../../components/resume/ResumeSection.astro';

const contactRows = [
  [
    { icon: 'phone', text: '15258927042' },
    { icon: 'mail', text: 'bakersean@foxmail.com' },
  ],
  [{ icon: 'monitor', text: 'https://bakersean.top/' }],
  [{ icon: 'github', text: 'https://github.com/BakerSean168/' }],
  [{ icon: 'briefcase', text: 'AI应用前端/全栈工程师' }],
];
---

<ResumePage title="AI Resume" description="我的专业简历" backHref="/about" backLabel="返回关于" printLabel="打印 / 保存为 PDF">
  <ResumeHeader name="卢楼豪" contactRows={contactRows} />

  <ResumeSection title="教育背景">
    <article>
      <div class="flex justify-between items-baseline mb-0.5 keep-together">
        <h3 class="font-bold text-[13.5px] text-foreground print:text-black">四川农业大学 <strong>（211）</strong></h3>
        <span>2022年09月 - 2026年06月</span>
      </div>
      <div class="flex justify-between items-baseline keep-together">
        <p>物联网工程 本科 信息工程学院 全日制</p>
        <span>雅安</span>
      </div>
      <div class="mt-1 text-muted-foreground print:text-gray-800 text-justify">
        <p><strong>主修课程：</strong>数据结构与算法、计算机网络、操作系统、数据库原理、Web前端开发技术等</p>
      </div>
    </article>
  </ResumeSection>

  <ResumeSection title="专业技能">
    <div class="space-y-1 text-justify">
      <p><strong>AI 大模型集成与应用开发：</strong>深刻理解 LLM 交互范式，熟练掌握 Prompt Engineering。熟悉大模型流式输出（SSE/Stream）在前端的接入与渲染，具备独立设计与落地 Chatbot、AI 知识管理、智能文档生成等全链路 AI Agent 应用的实战经验。</p>
      <p><strong>前端与工程化：</strong>熟练掌握 TypeScript 与现代 JavaScript (ES6+)。深度掌握 Vue3 及其生态，熟悉 React 18 及其 Hooks 机制。熟练使用 Vite、ESLint、Husky 等工程化工具，具备自动化发布（GitHub Actions）及单元测试配置能力。</p>
      <p><strong>全栈开发闭环能力：</strong>熟悉 Node.js 核心模块，了解 python， 熟悉 RESTful API 规范、JWT 鉴权及前后端标准数据流转。具备运用 Prisma 进行数据库建模及分布式复杂状态调度的能力，能够独立完成从数据库设计到前端呈现的完整业务闭环。</p>
      <p><strong>高性能 Web 开发与调优：</strong>熟练使用 Tailwind CSS 与各类现代组件库（Element Plus、Shadcn UI）。具备复杂数据可视化（ECharts）、纯 DOM 高清打印流重构、跨端跨页状态同步等核心痛点攻坚能力。</p>
      <p><strong>敏捷开发与创新效能：</strong>熟练使用 Figma 进行 UI 设计，具备良好的产品思维与交互嗅觉；高度善用 AI 工具（ChatGPT/Gemini/Cursor）辅助 Vibe Coding 及架构设计，持续探索 AI 赋能研发效能的最佳实践，拥有极强的技术自驱力与代码洁癖。</p>
    </div>
  </ResumeSection>

  <ResumeSection title="工作经历">
    <article class="mb-3">
      <div class="flex justify-between items-baseline mb-0.5 keep-together">
        <h3 class="font-bold text-[13.5px] text-foreground print:text-black">北京科睿金信技术有限公司</h3>
        <span>2025年07月 - 2025年11月</span>
      </div>
      <div class="flex justify-between items-baseline mb-1 keep-together">
        <p>前端工程师（实习） 国际产品应用开发部</p>
        <span>杭州</span>
      </div>
      <div class="space-y-0.5">
        <p>业务开发与重构：参与公司核心系统 OLP（在线学习平台）与 DDCC（档案管理系统）的前端迭代，基于 Vue3 + Element Plus 技术栈，独立负责并落地AI 知识管理模块从 0 到 1 的开发。</p>
        <p>技术痛点攻坚：针对业务中遗留的技术债务进行主动优化。进行 DDCC 项目中“复杂签名表跨页打印”的重构，摒弃低效的 Canvas 截图方案，实现原生 DOM 级高清打印；解决分页表格跨页时选中状态丢失的复杂状态同步问题。</p>
        <p>跨端与跨技术栈协作：不仅负责常规 Web 端开发，还深入参与底层会议系统的定制。在 Docker 环境下对开源系统 BigBlueButton 进行 React 源码级二次开发与界面重构，并独立排查多阶段构建时的缓存报错问题。</p>
        <p>工程化与规范：熟悉企业级敏捷开发流程与 Git 团队协作，利用已有的高复用性通用组件（如超级搜索、动态表单等），提升团队交付效率。</p>
      </div>
    </article>
  </ResumeSection>

  <ResumeSection title="项目经历">
    <article class="mb-3">
      <div class="flex justify-between items-baseline mb-0.5 keep-together">
        <h3 class="font-bold text-[13.5px] text-foreground print:text-black">OLP（在线学习平台）</h3>
        <span>2025年07月 - 2025年11月</span>
      </div>
      <div class="flex justify-between items-baseline mb-1 keep-together">
        <p>前端开发工程师（实习） 国际产品应用开发部</p>
        <span>杭州</span>
      </div>

      <div>
        <p class="font-bold text-foreground print:text-black mt-1.5 mb-0.5 keep-together">项目描述：</p>
        <p class="mb-1 text-justify">面向 Majnoon 油田等跨国企业的综合性内部培训与职业发展系统，涵盖线上音视频课程、直播、考试、AI 知识沉淀与岗位能力匹配等全流程体系。</p>

        <p class="font-bold text-foreground print:text-black mt-1.5 mb-0.5 keep-together">技术栈：</p>
        <p class="mb-1 text-justify text-primary print:text-black font-medium">Vue3 + TypeScript + Element Plus + Vite + ECharts</p>

        <p class="font-bold text-foreground print:text-black mt-1.5 mb-0.5 keep-together">核心职责：</p>
        <div class="space-y-0.5 text-justify">
          <p><strong>独立负责 AI 知识管理系统：</strong>主导用户端与管理端的知识生成、管理闭环。复用并改造大模型对话（Chatbot）组件，实现流式对话、自动提取摘要及标签打标功能；实现各类生成与上传文档的富文本渲染、在线预览及流式下载功能，完善管理端的批量审批与管理链路。</p>
          <p><strong>EDP（员工发展计划）模块开发：</strong>实现基于 AI 的岗位 JD 生成器与技能图谱匹配模块，处理复杂的级联数据回显。开发多维度的推荐学习内容搜索（按技能、匹配度、关键字精确/模糊查询），并实现手工更新与重算 AI 匹配度的交互逻辑。</p>
          <p><strong>复杂组件状态管理优化：</strong>修复管理端人员列表中因接口分页导致的“跨页选中状态丢失”缺陷，通过抽离全局选中对象与当前页视图状态，结合 isSettingSelection 锁机制，实现数据无缝翻页与表单回填，大幅提升交互体验。</p>
        </div>
      </div>
    </article>

    <article class="mb-3">
      <div class="flex justify-between items-baseline mb-0.5 keep-together">
        <h3 class="font-bold text-[13.5px] text-foreground print:text-black">DDCC（档案管理与线上协作系统）</h3>
        <span>2025年10月 - 2025年11月</span>
      </div>
      <div class="flex justify-between items-baseline mb-1 keep-together">
        <p>前端开发工程师（实习） 国际产品应用开发部</p>
      </div>

      <div>
        <p class="font-bold text-foreground print:text-black mt-1.5 mb-0.5 keep-together">项目描述：</p>
        <p class="mb-1 text-justify">包含高精度的档案业务流转平台，以及集成白板与实时字幕的线上会议室系统。</p>

        <p class="font-bold text-foreground print:text-black mt-1.5 mb-0.5 keep-together">技术栈：</p>
        <p class="mb-1 text-justify text-primary print:text-black font-medium">Vue3 + vue-print-next + pagedjs + React (BBB二次开发) + Docker</p>

        <p class="font-bold text-foreground print:text-black mt-1.5 mb-0.5 keep-together">核心职责：</p>
        <div class="space-y-0.5 text-justify">
          <p><strong>高精度报表打印模块重构：</strong>针对旧版 html2canvas 方案导致的报表打印模糊、长表格被拦腰截断、签名区无法跨页重复等痛点进行重构。</p>
          <p><strong>基于 pagedjs 的跨页排版落地：</strong>引入 vue-print-next 结合 pagedjs 排版引擎实现 DOM 级高清打印。利用 pagedjs 动态解析 CSS Paged Media 规范，精准计算页面边界与数据表自动分页；配合 vue-print-next 注入克隆 DOM，完美实现动态签批表在每一页 A4 纸底部的重复渲染。</p>
          <p><strong>BBB 视频会议系统二次开发：</strong>在测试服务器的 Docker 环境下，对基准版 BigBlueButton 的前端仓库（React / HTML5 客户端）进行定制开发。将原有的 Smart Caption（实时语音转文字）从独立悬浮窗重构集成至页面左侧抽屉面板（Sidebar），通过复用公共聊天的 UI 结构规范布局，显著提升了会议模式下的用户视觉体验与操作一致性。</p>
        </div>
      </div>
    </article>

    <article>
      <div class="flex justify-between items-baseline mb-0.5 keep-together">
        <h3 class="font-bold text-[13.5px] text-foreground print:text-black">Digital Biome（个人知识生态与导航系统）</h3>
        <span>2025年12月 - 2026年2月</span>
      </div>
      <div class="flex justify-between items-baseline mb-1 keep-together">
        <p>Github: https://github.com/BakerSean168/digital-biome</p>
      </div>

      <div>
        <p class="font-bold text-foreground print:text-black mt-1.5 mb-0.5 keep-together">项目描述：</p>
        <p class="mb-1 text-justify">基于 Astro 构建的高性能静态知识生态站点。项目与本地 Obsidian 知识库深度绑定，通过解析 Markdown 文件与层级标签，自动将其转化为包含工具导航（Dashboard）、沉浸式阅读（Notes）及专业简历等多种场景视图的线上数字花园，实现了内容创作与网页展示的无缝流转。</p>

        <p class="font-bold text-foreground print:text-black mt-1.5 mb-0.5 keep-together">技术栈：</p>
        <p class="mb-1 text-justify text-primary print:text-black font-medium">Astro + TypeScript + Tailwind CSS + Node.js + Pagefind</p>

        <p class="font-bold text-foreground print:text-black mt-1.5 mb-0.5 keep-together">项目亮点：</p>
        <div class="space-y-0.5 text-justify">
          <p><strong>工程化数据同步流构建：</strong>利用工程化的结构规范以及脚本文件，实现优雅的基于笔记内容的网页数据获取。</p>
          <p><strong>页面原型快速设计开发：</strong>通过 figma 进行元素、组件和页面地原型设计，再利用 ai 快速实现项目开发</p>
          <p><strong>前端架构设计与性能优化：</strong>采用 Astro 的静态优先策略（SSG）与 Islands 架构，大幅降低客户端 JS 体积。抽象出多套独立 Layout，优雅实现了同一数据源的跨场景渲染与极佳的打印排版支持。</p>
        </div>
      </div>
    </article>

    <article class="mb-3">
      <div class="flex justify-between items-baseline mb-0.5 keep-together">
        <h3 class="font-bold text-[13.5px] text-foreground print:text-black">知行 Memoflow（AI 驱动的个人效能管理系统）</h3>
        <span>2024年01月 - 至今 (持续维护)</span>
      </div>
      <div class="flex justify-between items-baseline mb-1 keep-together">
        <p>全栈独立开发（个人项目）</p>
        <span>Github: https://github.com/BakerSean168/DailyUse</span>
      </div>

      <div>
        <p class="font-bold text-foreground print:text-black mt-1.5 mb-0.5 keep-together">项目描述：</p>
        <p class="mb-1 text-justify">基于 Nx/pnpm Monorepo 构建的多端全栈 AI 效能管理应用，覆盖 Web、Desktop 与 AI Service，支持目标管理、任务调度、知识管理与 AI 对话等场景，重点打磨前端工程架构与 AI 交互体验。</p>

        <p class="font-bold text-foreground print:text-black mt-1.5 mb-0.5 keep-together">技术栈：</p>
        <p class="mb-1 text-justify text-primary print:text-black font-medium">Vue3、TypeScript、Electron、Node.js/Express、Prisma、FastAPI、LangGraph、Nx/pnpm Monorepo</p>

        <p class="font-bold text-foreground print:text-black mt-1.5 mb-0.5 keep-together">项目亮点：</p>
        <div class="space-y-0.5 text-justify">
          <p><strong>多端工程架构与自动化：</strong>构建 Nx Monorepo 多应用架构，拆分 Web、Desktop、API 与共享领域包，统一构建流程、类型检查与接口契约。配置 GitHub Actions 实现 Electron 桌面应用自动打包发布（跨平台构建与版本管理），支撑多端长期迭代。</p>
          <p><strong>AI Agent 工作台与交互设计：</strong>设计并实现 AI 工作台前端，涵盖 Agent 状态流转、事件时间线、流式对话与知识问答等交互组件。基于 Vue3 Composition API 封装 AI 对话组合式函数，实现流式响应渲染与草稿审批（interrupt/resume）前端控制流。</p>
          <p><strong>前端复杂状态解耦与聚合：</strong>针对配置项繁多的巨型表单，运用组件化思维拆解为多个细粒度视图（如基础信息、时间规则等）。提取自定义 Hook 集中调度分布式校验状态，严格遵循单向数据流原则，大幅降低代码耦合度。</p>
          <p><strong>全栈通信与鉴权基础设施：</strong>基于 Axios 封装 HTTP Client，运用 Result Pattern 抹平底层网络与业务异常。在拦截器中利用 Promise 锁机制与任务队列，实现严谨的 401 无感 Token 并发刷新机制。</p>
        </div>
      </div>
    </article>
  </ResumeSection>

  <ResumeSection title="技能证书">
    <div class="space-y-0.5">
      <p>• 计算机三级：网络技术</p>
      <p>• 语言：CET-6</p>
    </div>
  </ResumeSection>

 <ResumeSection title="个人总结">
    <div class="space-y-0.5">
      <p>• <strong>学习与钻研能力：</strong>大学英语六级，能够阅读英文技术文档与 API 文档。长期使用 Obsidian 沉淀技术笔记与知识体系,有构思自己的笔记体系，已经累计1000多篇笔记。并且钻研过家庭服务器、软路由、个人网站等多种技术，具备较强的动手实践与问题探索能力。</p>
      <p>• <strong>积极拥抱 AI 技术：</strong>持续学习并实践 AI 应用开发，熟悉 Cursor、Copilot、Claude Code 等 AI 辅助开发工具，善于挑选并配置 MCP 工具、Skills，为任务搭建高效的 AI 工作流环境。</p>
      <p>• <strong>问题沟通与文档化：</strong>善于使用 Markdown 文档记录、拆解问题，将信息结构化以便于团队交流与知识沉淀。注重需求理解与方案设计，能够通过清晰的文档与沟通推动问题解决与功能落地。</p>
    </div>
  </ResumeSection>
</ResumePage>
