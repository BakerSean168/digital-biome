---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AssetSection from '../../components/assets/AssetSection.astro';
import { getServiceDisplayGroups } from '../../utils/notes';

const { operations, projects } = await getServiceDisplayGroups();
---

<BaseLayout title="Services" description="公开服务资产列表">
  <main class="mx-auto max-w-7xl space-y-14 px-4 py-10 md:px-6 md:py-14">
    <AssetSection
      title="Runtime Services"
      description="这里是运维面、入口面和日常运行中的服务。详情页负责承载部署上下文，实时状态则跳转到哪吒或 Uptime Kuma。"
      assets={operations}
      emptyText="还没有公开的运行时服务资产。"
    />

    <AssetSection
      title="Projects & Sites"
      description="这些资产技术上仍然是服务，但它们更像产品、作品或公开展示站点，所以单独放成一组。"
      assets={projects}
      emptyText="还没有公开的项目型服务资产。"
      variant="project"
    />
  </main>
</BaseLayout>
