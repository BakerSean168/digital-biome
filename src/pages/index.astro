---
/**
 * 首页 - 数字化生命群落 & 生态树
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SoilSearch from '../components/dashboard/SoilSearch.astro';
import BiomeTree from '../components/dashboard/BiomeTree.astro';
import RecentSprouts from '../components/dashboard/RecentSprouts.astro';
import { SITE_NAME } from '../constants';
import { Github, Mail } from '@lucide/astro';
---

<BaseLayout title={SITE_NAME} bodyClass="bg-bg-deep min-h-screen relative overflow-x-hidden">
  <!-- 精美细腻的背景发光氛围 -->
  <div class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top_right,rgba(0,255,144,0.06),transparent_35%),radial-gradient(circle_at_20%_20%,rgba(6,182,212,0.04),transparent_25%)]"></div>
  <div class="fixed inset-0 -z-10 bg-[linear-gradient(180deg,rgba(11,15,25,0.2),transparent_50%)] bg-cyber-grid"></div>

  <main class="container mx-auto max-w-7xl px-4 md:px-6 pt-10 md:pt-14 pb-20 overflow-visible">
    
    <!-- 头部极简宣言区 -->
    <section class="mx-auto max-w-3xl text-center flex flex-col items-center gap-4">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-xs font-mono text-primary tracking-widest animate-pulse-soft">
        <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
        SYSTEM INITIALIZED: ONLINE
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight text-text-main sm:text-5xl font-mono mt-2 bg-clip-text text-transparent bg-gradient-to-b from-text-main via-text-main/90 to-text-main/70">
        心智之根，扎于探索的土壤
      </h1>
      <p class="mx-auto max-w-2xl text-xs leading-relaxed text-text-muted font-mono tracking-wide">
        我是卢楼豪 (BakerSean)，一名热衷于打磨用户体验的全栈工程师。这里是我的自建 Homelab、个人作品集与 1000+ 篇 Obsidian 笔记交织出的数字生态。
      </p>
    </section>

    <!-- 生态大树展示区 (DOM 卡片嵌套在其内部) -->
    <BiomeTree />

    <!-- 土壤智能搜索框 -->
    <SoilSearch />

    <!-- 近期萌芽模块 (动态与静态混合网格) -->
    <RecentSprouts />

    <!-- 底部连接握手区 (Uplink Connection Port) -->
    <section class="mt-20 max-w-4xl mx-auto px-4">
      <div class="relative bg-bg-panel/40 backdrop-blur-xl border border-border-soft p-6 md:p-8 rounded-2xl shadow-lg flex flex-col md:flex-row items-start md:items-center justify-between gap-6 overflow-hidden">
        <div class="absolute top-0 right-0 p-3 text-[10px] font-mono text-primary/30 select-none">
          PORT_HANDSHAKE: ACTIVE
        </div>
        
        <div class="flex flex-col gap-2 max-w-xl">
          <h4 class="text-base font-bold font-mono text-text-main flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-primary"></span>
            ESTABLISH_UPLINK / 建立连接
          </h4>
          <p class="text-xs text-text-muted leading-relaxed">
            物理网卡已就绪。无论是关于 Vue3/React 还原痛点交流、Obsidian 笔记流探讨，还是 Homelab 极客玩法，我的信箱随时欢迎握手。
          </p>
        </div>

        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="mailto:bakersean@foxmail.com" class="flex items-center gap-2 px-4 py-2 bg-primary/10 hover:bg-primary/20 border border-primary/40 text-primary text-xs font-mono rounded-lg transition-all">
            <Mail size={14} /> mailto:bakersean@foxmail.com
          </a>
          <a href="https://github.com/BakerSean168" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 bg-border-soft hover:bg-border-soft/80 border border-border-soft text-text-main text-xs font-mono rounded-lg transition-all">
            <Github size={14} /> GitHub
          </a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .bg-cyber-grid {
    background-image: radial-gradient(rgba(0, 255, 144, 0.03) 1px, transparent 1px);
    background-size: 24px 24px;
  }
</style>
