---
/**
 * 首页 - 数字化生命群落 & 生态树 (Basalt & Moss Edition)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BiomeTree from '../components/dashboard/BiomeTree.astro';
import { SITE_NAME } from '../constants';
---

<BaseLayout title={SITE_NAME} bodyClass="h-screen w-screen overflow-hidden bg-background relative text-foreground">
  <!-- Wabi-Sabi Noise Overlay (Organic Texture) -->
  <div class="absolute inset-0 -z-10 opacity-[0.03] pointer-events-none mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
  
  <!-- Subtle dark vignette to focus center -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(21,22,20,0.8)_100%)]"></div>

  <main class="relative w-full h-full flex items-center justify-center">
    
    <!-- Center Absolute Graph (The Seed) -->
    <div class="relative z-10 w-full max-w-5xl scale-90 md:scale-100 flex justify-center items-center">
      <!-- We reuse BiomeTree but rely on the new CSS variables and neural-pulse classes in global.css -->
      <BiomeTree />
    </div>

    <!-- Top Right Telemetry (Telemetry Data) -->
    <div class="absolute top-8 right-8 text-right font-mono text-[10px] text-muted-foreground leading-relaxed flex flex-col items-end opacity-60">
      <div class="flex items-center gap-2 mb-1">
        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse-soft"></span>
        <span>SYS.TELEMETRY_ACTIVE</span>
      </div>
      <div>UPTIME: 99.98%</div>
      <div>NODES_INDEXED: 1042</div>
      <div class="text-border">HASH: 7f8a9b2</div>
      <div class="mt-2 pt-2 border-t border-border/50 text-[9px] text-tertiary-foreground">
        ATMOSPHERE: STABLE
      </div>
    </div>

    <!-- Bottom Left Identity Block (The Root) -->
    <div class="absolute bottom-10 left-10 flex flex-col items-start z-20">
      <h1 class="font-sans font-bold text-4xl tracking-tighter text-foreground mb-1">BakerSean</h1>
      <div class="font-mono text-xs text-muted-foreground tracking-widest uppercase mb-2">
        DIGITAL BIOME v2.0 // Wabi-Sabi
      </div>
      <div class="font-mono text-[11px] text-primary/80 flex items-center gap-1.5">
        <span class="opacity-70">AWAITING_INPUT</span>
        <span class="inline-block w-2 h-3.5 bg-primary/70 animate-[pulse_1s_step-end_infinite]"></span>
      </div>
    </div>
    
  </main>
</BaseLayout>
