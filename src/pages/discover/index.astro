---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SignalTitle from '../../components/common/SignalTitle.astro';
import { getPublicAssets, getAssetHref } from '../../utils/notes';

const assetEntries = getPublicAssets();

const assetResults = assetEntries.map(entry => ({
  id: entry.data.asset_id!,
  scope: 'assets',
  kind: entry.data.asset_type!,
  label: entry.data.asset_type!,
  title: entry.data.title,
  description: entry.data.description || '',
  tags: entry.data.tags || [],
  href: getAssetHref(entry.data),
}));

const initialQuery = Astro.url.searchParams.get('q') || '';
const initialScope = Astro.url.searchParams.get('scope') || 'all';
---

<BaseLayout title="Discover" description="[ GLOBAL_INDEX ] 全域高亮索引">
  <main class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-14">
    <section class="border-b border-border bg-transparent pb-8">
      <p class="text-xs font-mono uppercase tracking-widest text-primary/80">Discover</p>
      <SignalTitle as="h1" class="mt-3 text-4xl font-bold font-mono tracking-tight text-foreground" title="搜索资产与知识笔记" />
      <p class="mt-3 max-w-3xl text-sm font-mono leading-7 text-muted-foreground">
        这里统一检索服务、工具、主机、网络和普通笔记。搜索结果会明确标注类型。
      </p>

      <div class="mt-6 flex flex-col gap-4 md:flex-row md:items-center">
        <input
          id="discover-query"
          type="search"
          value={initialQuery}
          placeholder="Query the biome... (e.g. Astro, PVE, 领域驱动)"
          class="w-full border border-border bg-background px-4 py-3 font-mono text-sm text-foreground outline-none transition-colors focus:border-primary/50"
        />
        <select
          id="discover-scope"
          class="border border-border bg-background px-4 py-3 font-mono text-sm text-foreground outline-none transition-colors focus:border-primary/50"
        >
          <option value="all" selected={initialScope === 'all'}>全部</option>
          <option value="assets" selected={initialScope === 'assets'}>仅资产</option>
          <option value="notes" selected={initialScope === 'notes'}>仅笔记</option>
        </select>
      </div>
    </section>

    <section class="mt-8">
      <div class="mb-4 text-xs font-mono tracking-widest text-muted-foreground" id="discover-count"></div>
      <div id="discover-results" class="grid gap-4 md:grid-cols-2 xl:grid-cols-3"></div>
      <div id="discover-empty" class="hidden border border-dashed border-border bg-card/40 px-6 py-10 text-sm font-mono text-muted-foreground">
        没有匹配结果，试试更短的关键词，或者切换到“全部”范围。
      </div>
      <div id="discover-dev-warning" class="hidden border border-amber-500/20 bg-amber-500/5 p-6 text-sm font-mono text-amber-500 mt-4">
        ⚠️ 开发环境下未检测到 Pagefind 索引，目前仅展示资产数据。如需验证完整的知识笔记搜索，请先执行 <code>pnpm build</code> 进行打包。
      </div>
    </section>
  </main>
</BaseLayout>

<script define:vars={{ assetResults, initialQuery, initialScope }}>
  const queryInput = document.getElementById('discover-query');
  const scopeInput = document.getElementById('discover-scope');
  const resultsEl = document.getElementById('discover-results');
  const countEl = document.getElementById('discover-count');
  const emptyEl = document.getElementById('discover-empty');
  const devWarningEl = document.getElementById('discover-dev-warning');

  let pagefind = null;

  async function loadPagefind() {
    if (pagefind) return pagefind;
    try {
      // @ts-ignore
      pagefind = await import('/pagefind/pagefind.js');
      // @ts-ignore
      await pagefind.init();
      devWarningEl?.classList.add('hidden');
      return pagefind;
    } catch (e) {
      console.warn('Pagefind is not available in dev mode.', e);
      if (queryInput?.value.trim()) {
        devWarningEl?.classList.remove('hidden');
      }
      return null;
    }
  }

  function render(items) {
    if (!resultsEl || !countEl || !emptyEl) return;

    countEl.textContent = `共 ${items.length} 条结果`;
    resultsEl.innerHTML = '';

    if (items.length === 0) {
      emptyEl.classList.remove('hidden');
      return;
    }

    emptyEl.classList.add('hidden');
    const fragment = document.createDocumentFragment();

    items.forEach(item => {
      const card = document.createElement('a');
      card.href = item.href;
      card.className = 'group border border-border bg-transparent p-5 transition-all duration-300 hover:border-primary/40 hover:bg-card/40';
      card.innerHTML = `
        <div class="mb-3 flex items-center gap-2">
          <span class="border border-primary/20 bg-primary/10 px-2 py-0.5 text-[10px] font-mono tracking-widest text-primary">${item.label}</span>
          <span class="text-[10px] font-mono text-muted-foreground tracking-widest">[ ${item.scope.toUpperCase()} ]</span>
        </div>
        <h2 class="text-xl font-serif text-foreground group-hover:text-primary transition-colors">${item.title}</h2>
        <p class="mt-2 line-clamp-3 text-sm leading-6 text-muted-foreground font-mono">${item.description || '[ EMPTY_SLOT ]'}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          ${(item.tags || []).slice(0, 4).map(tag => `<span class="border border-border bg-transparent px-2 py-0.5 text-[10px] font-mono text-muted-foreground">#${tag.includes('/') ? tag.split('/').pop() : tag}</span>`).join('')}
        </div>
      `;
      fragment.appendChild(card);
    });

    resultsEl.appendChild(fragment);
  }

  async function filterResults() {
    const query = (queryInput?.value || '').trim().toLowerCase();
    const scope = scopeInput?.value || 'all';

    // 1. Update URL search params
    const url = new URL(window.location.href);
    if (query) {
      url.searchParams.set('q', query);
    } else {
      url.searchParams.delete('q');
    }
    if (scope !== 'all') {
      url.searchParams.set('scope', scope);
    } else {
      url.searchParams.delete('scope');
    }
    window.history.replaceState({}, '', url);

    // 2. Query empty state
    if (!query) {
      devWarningEl?.classList.add('hidden');
      if (scope === 'notes') {
        render([]);
        if (countEl) countEl.textContent = '请输入关键词开始搜索 2400+ 篇知识笔记...';
      } else {
        // Show assets when empty query
        const filteredAssets = assetResults.filter(item => {
          return scope === 'all' || item.scope === scope;
        });
        render(filteredAssets);
      }
      return;
    }

    // 3. Try searching notes and assets via Pagefind
    const pf = await loadPagefind();
    if (pf) {
      devWarningEl?.classList.add('hidden');
      try {
        const search = await pf.search(query);
        const rawResults = await Promise.all(search.results.map(r => r.data()));
        
        const formatted = rawResults.map(item => {
          const itemUrl = item.url;
          let itemScope = 'notes';
          let label = 'note';
          
          if (itemUrl.includes('/services/')) {
            itemScope = 'assets';
            label = 'service';
          } else if (itemUrl.includes('/tools/')) {
            itemScope = 'assets';
            label = 'tool';
          } else if (itemUrl.includes('/infrastructure/')) {
            itemScope = 'assets';
            label = 'host';
          }
          
          // Use Pagefind's excerpt
          const description = item.excerpt || '';
          const title = item.meta?.title || itemUrl.split('/').pop()?.replace(/-/g, ' ') || 'Untitled';
          
          return {
            id: itemUrl,
            scope: itemScope,
            kind: label,
            label: label,
            title: title,
            description: description,
            tags: [],
            href: itemUrl,
          };
        });

        const filtered = formatted.filter(item => {
          if (scope === 'all') return true;
          return item.scope === scope;
        });

        render(filtered);
        return;
      } catch (err) {
        console.error('Error querying Pagefind:', err);
      }
    }

    // 4. Fallback search (only searches assets in memory)
    devWarningEl?.classList.remove('hidden');
    const filteredAssets = assetResults.filter(item => {
      const matchesScope = scope === 'all' || item.scope === scope;
      const haystack = [item.title, item.description, item.id, ...(item.tags || [])]
        .join(' ')
        .toLowerCase();
      const matchesQuery = haystack.includes(query);
      return matchesScope && matchesQuery;
    });

    render(filteredAssets);
  }

  // Debounce helper
  let debounceTimeout = null;
  function handleInput() {
    if (debounceTimeout) clearTimeout(debounceTimeout);
    debounceTimeout = setTimeout(() => {
      filterResults();
    }, 150);
  }

  queryInput?.addEventListener('input', handleInput);
  scopeInput?.addEventListener('change', filterResults);

  // Initial load
  if (queryInput && initialQuery) {
    queryInput.value = initialQuery;
  }
  filterResults();
</script>
