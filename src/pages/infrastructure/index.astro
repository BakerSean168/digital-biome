---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InfrastructureShowcase from '../../components/assets/InfrastructureShowcase.astro';
import {
  featuredInfrastructureAssetIds,
  getInfrastructureDataset,
  getTopologyFactCounts,
  getTopologyFlows,
  homelabFlowIds,
  pickAssetCardsByIds,
  publicFleetFlowIds,
} from '../../utils/infrastructure';

const { assetCards, resolvedNodes } = await getInfrastructureDataset();
const fleetFlows = getTopologyFlows(publicFleetFlowIds);
const homelabFlows = getTopologyFlows(homelabFlowIds);
const fleetFacts = getTopologyFactCounts(fleetFlows);
const homelabFacts = getTopologyFactCounts(homelabFlows);
const featuredAssets = pickAssetCardsByIds(assetCards, featuredInfrastructureAssetIds);

const heroFacts = [
  '4 个公网区域：成都、香港、日本、韩国',
  `${fleetFacts.flowCount} 条公网链路，覆盖控制面、业务面、代理面与展示面`,
  `${homelabFacts.flowCount} 条家庭实验室链路，包含供电、网络、计算、虚拟化与服务层`,
  `${assetCards.length} 个资产化节点，已接入详情页、入口和监控跳板`,
];
---

<BaseLayout title="Infrastructure" description="家庭网络与公网资产">
  <main class="mx-auto max-w-7xl px-4 py-10 md:px-6 md:py-14">
    <InfrastructureShowcase
      title="数字基础设施拓扑"
      description="这里不再把服务器、路由器和服务拆散成零碎卡片，而是把公网控制平面、区域 VPS 舰队、公开站点、家庭网络和 Homelab 服务栈编织成一个完整的个人基础设施展示站。"
      heroFacts={heroFacts}
      featuredAssets={featuredAssets}
      resolvedNodes={resolvedNodes}
      locale="zh"
    />
  </main>
</BaseLayout>
