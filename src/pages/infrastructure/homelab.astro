---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InfrastructureTopologyMap, { type TopologyTier } from '../../components/assets/InfrastructureTopologyMap.astro';
import type { ResolvedTopologyNode } from '../../utils/infrastructure';
import {
  getAssetCardsForFlows,
  getInfrastructureDataset,
  getTopologyFlows,
  homelabLayers,
  homelabFlowIds,
} from '../../utils/infrastructure';

const homelabFlows = getTopologyFlows(homelabFlowIds);
const { assetCards, resolvedNodes } = getInfrastructureDataset();
const homelabAssets = getAssetCardsForFlows(homelabFlows, assetCards);

const tiers: TopologyTier[] = homelabLayers.map(layer => {
  const allNodes = layer.nodeIds.map(id => resolvedNodes[id]).filter(Boolean);
  
  const items: {node: ResolvedTopologyNode, services: ResolvedTopologyNode[]}[] = [];
  let currentItem: {node: ResolvedTopologyNode, services: ResolvedTopologyNode[]} | null = null;
  
  for (const n of allNodes) {
    if (n.kind === 'service' || n.kind === 'tool' || n.kind === 'vm') {
      if (currentItem) {
        currentItem.services.push(n);
      } else {
        items.push({ node: n, services: [] });
      }
    } else {
      currentItem = { node: n, services: [] };
      items.push(currentItem);
    }
  }

  return {
    id: layer.id,
    title: `${layer.level} - ${layer.title}`,
    description: layer.description,
    items: items.length > 0 ? items : allNodes.map(node => ({ node, services: [] }))
  };
});
---

<BaseLayout title="Homelab" description="家庭网络、PVE、NAS 与家庭服务栈">
  <main class="mx-auto max-w-7xl px-4 py-10 md:px-6 md:py-14">
    <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-primary/75">Infrastructure Detail</p>
        <h1 class="mt-2 text-3xl font-semibold text-foreground md:text-4xl">Homelab View</h1>
        <p class="mt-3 max-w-3xl text-sm leading-6 text-muted-foreground md:text-base">
          这里专门展开家庭网络内部，把供电、网络、主机、虚拟机、NAS 和核心家庭服务拆开看，保留 Homelab 的层级感和设备关系。
        </p>
      </div>
      <a href="/infrastructure" class="text-sm text-primary transition-colors hover:text-foreground">
        返回基础设施总览
      </a>
    </div>

    <InfrastructureTopologyMap
      title="家庭网络与 Homelab 拓扑"
      description="这张页面把家庭网络真正按拓扑结构拆开：从供电韧性、接入与交换、N100 + PVE 底座，再到虚拟机编排和家庭服务入口，形成一张层层递进的节点视图。"
      tiers={tiers}
    />
  </main>
</BaseLayout>
