---
import { render } from 'astro:content';
import AssetDetailView from '../../components/assets/AssetDetailView.astro';
import { getAssetsByType, getRelatedAssetsByParent, toAssetCard } from '../../utils/notes';

export const prerender = true;

export async function getStaticPaths() {
  const hosts = await getAssetsByType('host');
  const networks = await getAssetsByType('network');
  return [...hosts, ...networks].map(entry => ({
    params: { assetId: entry.data.asset_id },
    props: { entry },
  }));
}

import type { AssetNoteEntry } from '../../types/notes';
import type { TopologyTier } from '../../components/assets/InfrastructureTopologyMap.astro';
import { getInfrastructureDataset } from '../../utils/infrastructure';

interface Props {
  entry: AssetNoteEntry;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const relatedAssets = (await getRelatedAssetsByParent(entry.data.asset_id)).map(toAssetCard);
const { resolvedNodes } = await getInfrastructureDataset();

// Build sub-topology from related assets
let subTopology: TopologyTier[] = [];
if (relatedAssets.length > 0) {
  const childNodes = relatedAssets
    .map(asset => Object.values(resolvedNodes).find(n => n.assetId === asset.assetId))
    .filter(Boolean) as any[];

  if (childNodes.length > 0) {
    const items: any[] = [];
    let currentItem: any = null;
    
    for (const n of childNodes) {
      if (n.kind === 'service' || n.kind === 'tool' || n.kind === 'vm') {
        if (currentItem) {
          currentItem.services.push(n);
        } else {
          items.push({ node: n, services: [] });
        }
      } else {
        currentItem = { node: n, services: [] };
        items.push(currentItem);
      }
    }

    subTopology = [{
      id: 'sub-topology',
      title: 'Deployed Assets',
      items: items.length > 0 ? items : childNodes.map(n => ({ node: n, services: [] }))
    }];
  }
}
---

<AssetDetailView entry={entry} Content={Content} relatedAssets={relatedAssets} subTopology={subTopology} />
