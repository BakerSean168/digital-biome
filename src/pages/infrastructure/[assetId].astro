---
import { getEntry, render } from 'astro:content';
import AssetDetailView from '../../components/assets/AssetDetailView.astro';
import { getAssetsByType, getRelatedAssetsByParent, toAssetCard } from '../../utils/notes';

export const prerender = true;

export async function getStaticPaths() {
  const hosts = getAssetsByType('host');
  const networks = getAssetsByType('network');
  return [...hosts, ...networks].map(entry => ({
    params: { assetId: entry.data.asset_id },
    props: { entry },
  }));
}

import type { AssetNoteEntry } from '../../types/notes';
import type { TopologyTier } from '../../components/assets/InfrastructureTopologyMap.astro';
import { getInfrastructureDataset } from '../../utils/infrastructure';

interface Props {
  entry: AssetNoteEntry;
}

const { entry } = Astro.props;

// Dual-channel rendering:
//   - Metadata (title, tags, monitor, links…) comes from `entry` which is
//     assembled from the asset-index (enriched with upstream nested fields).
//   - Body is rendered from the real Astro Collection entry. The compat entry
//     produced by assets-repository has body: '' and rendered: undefined, so
//     calling render() on it yields an empty <Content />. We must look up the
//     real CollectionEntry by note id and render that instead.
const noteId = entry.id; // e.g. "obsidian/assets/hosts/aliyun-chengdu-dailyuse-vps"
const realEntry = await getEntry('notes', noteId);
const { Content } = realEntry
  ? await render(realEntry)
  : await render(entry); // fallback: renders empty but doesn't crash

const relatedAssets = getRelatedAssetsByParent(entry.data.asset_id).map(toAssetCard);
const { resolvedNodes } = getInfrastructureDataset();

// Build sub-topology from related assets
let subTopology: TopologyTier[] = [];
if (relatedAssets.length > 0) {
  const childNodes = relatedAssets
    .map(asset => Object.values(resolvedNodes).find(n => n.assetId === asset.assetId))
    .filter(Boolean) as any[];

  if (childNodes.length > 0) {
    const items: any[] = [];
    let currentItem: any = null;
    
    for (const n of childNodes) {
      if (n.kind === 'service' || n.kind === 'tool' || n.kind === 'vm') {
        if (currentItem) {
          currentItem.services.push(n);
        } else {
          items.push({ node: n, services: [] });
        }
      } else {
        currentItem = { node: n, services: [] };
        items.push(currentItem);
      }
    }

    subTopology = [{
      id: 'sub-topology',
      title: 'Deployed Assets',
      items: items.length > 0 ? items : childNodes.map(n => ({ node: n, services: [] }))
    }];
  }
}
---

<AssetDetailView entry={entry} Content={Content} relatedAssets={relatedAssets} subTopology={subTopology} />
