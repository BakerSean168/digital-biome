---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { formatDate } from '../../../utils/date';
import { SITE_NAME } from '../../../constants';

export async function getStaticPaths() {
  const noteEntries = await getCollection('notes', ({ id }) => {
    return id.startsWith('en/') || !id.includes('/'); // fallback
  });
  return noteEntries.map(entry => ({
    params: { slug: entry.slug.replace(/^en\//, '') }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout
  title={`${entry.data.title} | ${SITE_NAME}`}
  description={entry.data.description || 'Note detail page'}
  type="article"
>
  <main class="max-w-4xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <article class="prose dark:prose-invert max-w-none">
      <h1 class="text-4xl font-bold mb-4">{entry.data.title}</h1>

      <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground mb-8 pb-4 border-b border-border">
        {entry.data.date && (
          <time datetime={entry.data.date.toISOString()}>
            Published: {formatDate(entry.data.date)}
          </time>
        )}

        {entry.data.updated && (
          <time datetime={entry.data.updated.toISOString()} class="flex items-center gap-1 before:content-['•'] before:mr-3">
            Updated: {formatDate(entry.data.updated)}
          </time>
        )}

        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 ml-auto">
            {entry.data.tags.map(tag => (
              <span class="px-2.5 py-0.5 rounded-full bg-primary/10 text-primary border border-primary/20 text-xs font-medium">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </div>

      <div class="mt-8 note-content">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

<style is:global>
  @reference "../../../styles/global.css";

  /* Base typography overrides */
  .note-content h1,
  .note-content h2,
  .note-content h3,
  .note-content h4,
  .note-content h5,
  .note-content h6 {
    @apply text-foreground font-bold scroll-mt-20;
    margin-top: 2em;
    margin-bottom: 0.75em;
  }

  .note-content h2 { @apply text-2xl border-b border-border pb-2; }
  .note-content h3 { @apply text-xl; }
  .note-content h4 { @apply text-lg; }

  .note-content p {
    @apply text-foreground leading-7 mb-4;
  }

  .note-content a {
    @apply text-primary underline decoration-primary/30 underline-offset-4 hover:decoration-primary transition-colors;
  }

  .note-content strong {
    @apply text-foreground font-semibold;
  }

  /* Blockquotes */
  .note-content blockquote {
    @apply border-l-4 border-primary pl-4 py-1 my-6 italic text-muted-foreground bg-primary/5 rounded-r-lg;
  }

  /* Lists */
  .note-content ul {
    @apply list-disc list-outside pl-6 mb-6 text-foreground space-y-2 marker:text-muted-foreground;
  }

  .note-content ol {
    @apply list-decimal list-outside pl-6 mb-6 text-foreground space-y-2 marker:text-muted-foreground font-medium;
  }

  .note-content li > p {
    @apply mb-0 inline;
  }

  /* Inline Code */
  .note-content code:not([class*="language-"]) {
    @apply bg-background-secondary text-primary px-1.5 py-0.5 rounded-md text-sm font-mono border border-border;
  }

  /* Code Blocks (Shiki will provide the base styles, we just tweak the container) */
  .note-content pre {
    @apply p-4 rounded-xl my-6 overflow-x-auto border border-border bg-card;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .note-content pre code {
    @apply text-sm font-mono leading-relaxed bg-transparent p-0 border-0 text-inherit;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  }

  /* Tables */
  .note-content table {
    @apply w-full text-left border-collapse my-6 text-sm text-foreground;
  }

  .note-content thead {
    @apply bg-background-secondary;
  }

  .note-content th {
    @apply px-4 py-3 font-semibold border border-border text-foreground;
  }

  .note-content td {
    @apply px-4 py-3 border border-border align-top;
  }

  .note-content tr:nth-child(even) {
    @apply bg-background-secondary/50;
  }

  /* Images */
  .note-content img {
    @apply rounded-xl border border-border shadow-sm max-w-full h-auto my-6 mx-auto;
  }

  /* HR */
  .note-content hr {
    @apply border-border my-10;
  }

  /* Task Lists (GitHub Flavored Markdown) */
  .note-content .contains-task-list {
    @apply list-none pl-0;
  }

  .note-content .task-list-item {
    @apply flex items-start gap-2;
  }

  .note-content input[type="checkbox"] {
    @apply mt-1.5 w-4 h-4 rounded border-border text-primary focus:ring-primary focus:ring-offset-background bg-background;
  }
</style>
