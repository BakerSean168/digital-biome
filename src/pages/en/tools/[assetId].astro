---
import { render } from 'astro:content';
import AssetDetailView from '../../../components/assets/AssetDetailView.astro';
import { getAssetsByType, getRelatedAssetsByParent, toAssetCard } from '../../../utils/notes';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getAssetsByType('tool');
  return entries.map(entry => ({
    params: { assetId: entry.data.asset_id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const relatedAssets = (await getRelatedAssetsByParent(entry.data.asset_id)).map(toAssetCard).map(asset => ({ ...asset, href: `/en${asset.href}` }));
---

<AssetDetailView entry={entry} Content={Content} relatedAssets={relatedAssets} />
