---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookmarkGrid from '../../components/dashboard/BookmarkGrid.astro';
---

<BaseLayout title="Tools" description="公开工具资产列表">
  <main class="mx-auto max-w-7xl px-4 py-10 md:px-6 md:py-14">
    <section class="space-y-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <h1 class="text-3xl font-semibold tracking-tight text-foreground">Tools</h1>
          <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">
            这里回到旧版导航页的语义，专门放你在笔记里沉淀下来的外部工具网站，而不是自建服务、监控面板或基础设施资产。
          </p>
        </div>
      </div>

      <BookmarkGrid />
    </section>
  </main>
</BaseLayout>
