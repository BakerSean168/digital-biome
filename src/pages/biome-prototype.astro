---
import {
  Archive,
  BookOpen,
  FlaskConical,
  Gamepad2,
  Github,
  Leaf,
  Mail,
  Music4,
  NotebookText,
  Film,
  Sparkles,
  Trees,
  UserRound,
  Wrench,
} from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { AUTHOR_EMAIL, SITE_NAME, SOCIAL_LINKS } from '../constants';
import {
  getHomepageAssets,
  getInfrastructureAssets,
  getPublicAssets,
  getPublicNotes,
  getRecentNotes,
} from '../utils/notes';
import BiomeNode from '../components/biome/BiomeNode.astro';
import BiomeSearch from '../components/biome/BiomeSearch.astro';
import RecentGrowthCard from '../components/biome/RecentGrowthCard.astro';

const [allNotes, recentNotes, projects, services, infrastructure, publicAssets] = await Promise.all([
  getPublicNotes(),
  getRecentNotes(4),
  getHomepageAssets('projects'),
  getHomepageAssets('services'),
  getInfrastructureAssets(),
  getPublicAssets(),
]);

const noteCount = allNotes.length;
const buildCount = projects.length + services.length;
const labCount = infrastructure.length;
const lifeCount = allNotes.filter((note) => (note.data.tags || []).some((tag) => tag.startsWith('life/'))).length;
const entertainmentCount = allNotes.filter((note) =>
  (note.data.tags || []).some((tag) =>
    tag.startsWith('recreation/') || tag.startsWith('media/video') || tag.startsWith('media/music')
  )
).length;

function extractLeafTag(tags: string[] = []) {
  return tags[0]?.split('/').pop() || 'recent';
}

function stripMarkdown(input: string) {
  return input
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/\[\[([^\]|]+)(\|([^\]]+))?\]\]/g, '$3$1')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[#>*_\-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function excerpt(body: string, description?: string, fallback = '继续向下展开这个分支。') {
  const fromDescription = description?.trim();
  if (fromDescription) {
    return fromDescription;
  }

  const cleaned = stripMarkdown(body);
  return cleaned.length > 84 ? `${cleaned.slice(0, 84)}...` : cleaned || fallback;
}

function normalizeEmail(email: string) {
  return email.includes('example.com') ? 'hello@digitalbiome.dev' : email;
}

const recentProject = projects[0] || services[0];
const recentInfra = infrastructure[0];

const noteSamples = ['Thoughts', 'Ideas', 'Learnings'];
const buildSamples = [recentProject?.title || 'Projects', 'Code', 'Design'];
const gameSamples = ['Steam', 'Immersion', 'Narrative'];
const movieSamples = ['镜头语言', '叙事结构', '情绪余韵'];
const musicSamples = ['Playlist', 'Mood', 'Replay'];
const lifeSamples = ['生活片段', '身体感受', '慢慢生长'];
const labSamples = [
  ...infrastructure.slice(0, 2).map((item) => item.title),
  ...publicAssets
    .filter((asset) => (asset.data.tags || []).some((tag) => tag.startsWith('tech/ops') || tag.startsWith('tech/network')))
    .slice(0, 1)
    .map((asset) => asset.data.title),
].filter((title): title is string => Boolean(title));

const recentGrowth: Array<{
  title: string;
  excerpt: string;
  meta: string;
  label: string;
  href: string;
  accent: string;
  glow: string;
  icon: any;
  tone: string;
}> = recentNotes.slice(0, 3).map((note, index) => ({
    title: note.data.title,
    excerpt: excerpt(note.body || '', note.data.description),
    meta: `${extractLeafTag(note.data.tags || [])} / 思考`,
    label: index === 0 ? 'Note / 最近更新' : 'Note / 生长记录',
    href: `/notes/${note.id.replace(/^obsidian\//, '')}`,
    accent: ['#67e8f9', '#4ade80', '#c084fc'][index] || '#67e8f9',
    glow: ['rgba(103,232,249,0.34)', 'rgba(74,222,128,0.32)', 'rgba(192,132,252,0.3)'][index] || 'rgba(103,232,249,0.34)',
    icon: index === 1 ? NotebookText : BookOpen,
    tone: [
      'from-cyan-400/28 via-slate-950/25 to-slate-950/95',
      'from-emerald-400/26 via-slate-950/25 to-slate-950/95',
      'from-violet-400/24 via-slate-950/20 to-slate-950/95',
    ][index],
  }));

if (recentProject) {
  recentGrowth.push({
    title: recentProject.title,
    excerpt: recentProject.description || '把想法、工程和体验交织成真实的作品分支。',
    meta: 'Project / 创造之枝',
    label: 'Build / 作品节点',
    href: recentProject.href,
    accent: '#34d399',
    glow: 'rgba(52,211,153,0.3)',
    icon: Wrench,
    tone: 'from-emerald-300/24 via-slate-950/25 to-slate-950/95',
  });
}

if (recentInfra) {
  recentGrowth.push({
    title: recentInfra.title,
    excerpt: recentInfra.description || '基础设施像菌丝一样在底层输送稳定性和实验空间。',
    meta: 'Lab / 基础设施',
    label: 'Lab / 小侧枝',
    href: recentInfra.href,
    accent: '#2dd4bf',
    glow: 'rgba(45,212,191,0.28)',
    icon: FlaskConical,
    tone: 'from-teal-300/24 via-slate-950/25 to-slate-950/95',
  });
}

const contactEmail = normalizeEmail(AUTHOR_EMAIL);
---

<BaseLayout
  title={`Biome Prototype | ${SITE_NAME}`}
  description="高保真首页原型：一张从搜索土壤生长出来的个人生命力地图。"
  bodyClass="biome-page"
  showHeader={false}
  showFooter={false}
>
  <main class="relative overflow-x-hidden text-white">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute inset-x-0 top-0 h-56 bg-[radial-gradient(circle_at_top,rgba(52,211,153,0.18),transparent_58%)]"></div>
      <div class="absolute left-[-12rem] top-36 h-96 w-96 rounded-full bg-cyan-400/10 blur-[140px]"></div>
      <div class="absolute right-[-8rem] top-24 h-[26rem] w-[26rem] rounded-full bg-emerald-400/10 blur-[160px]"></div>
      <div class="absolute bottom-0 left-1/2 h-[28rem] w-[56rem] -translate-x-1/2 rounded-full bg-cyan-300/10 blur-[180px]"></div>
    </div>

    <section class="relative">
      <div class="mx-auto max-w-[1440px] px-4 pb-10 pt-6 sm:px-6 md:pb-14 lg:px-10 lg:pt-8">
        <div class="biome-hero-shell rounded-[32px] px-4 py-5 sm:px-6 lg:px-8 lg:py-7">
          <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
            <div class="max-w-xl">
              <p class="text-[0.72rem] uppercase tracking-[0.4em] text-emerald-200/60">
                Personal Vitality Map
              </p>
              <div class="mt-4 flex items-center gap-4">
                <span class="flex h-14 w-14 items-center justify-center rounded-2xl border border-emerald-300/18 bg-emerald-300/8 text-emerald-200 shadow-[0_0_34px_rgba(16,185,129,0.28)]">
                  <Trees size={28} />
                </span>
                <div>
                  <h1 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:text-[3.35rem]">
                    {SITE_NAME}
                  </h1>
                  <p class="mt-1 text-sm text-white/56 sm:text-base">
                    心智之根，扎于探索的土壤
                  </p>
                </div>
              </div>
            </div>

            <nav class="flex flex-wrap items-center gap-2 text-sm text-white/70">
              <a href="/discover" class="biome-nav-pill">
                <Archive size={16} />
                <span>Archive</span>
              </a>
              <a href="/about" class="biome-nav-pill">
                <UserRound size={16} />
                <span>About</span>
              </a>
              <a href={`mailto:${contactEmail}`} class="biome-nav-pill">
                <Mail size={16} />
                <span>Contact</span>
              </a>
            </nav>
          </div>

          <div class="mt-8 flex flex-col gap-3 lg:mt-10 lg:flex-row lg:items-end lg:justify-between">
            <div class="max-w-3xl">
              <h2 class="text-3xl font-semibold tracking-tight text-white/94 sm:text-4xl lg:text-[3rem]">
                首页不是功能入口集合，而是一张会继续长大的数字生态图。
              </h2>
              <p class="mt-4 max-w-2xl text-base leading-8 text-white/58 sm:text-lg">
                搜索是土壤，根系是数据与记忆，树干承载你的成长路径，分支则把思考、创造、娱乐、生活与实验都连接回同一个人。
              </p>
            </div>

            <div class="rounded-[24px] border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-white/54 backdrop-blur-xl">
              <div class="flex items-center gap-2 text-emerald-200/80">
                <Sparkles size={16} />
                <span>搜索优先 / 内容驱动 / Lab 退居侧枝</span>
              </div>
            </div>
          </div>

          <div id="biome-hero" class="biome-hero-visual relative mt-8 rounded-[34px] px-2 py-4 sm:px-4 lg:mt-10 lg:px-6 lg:py-8">
            <div class="biome-grid pointer-events-none absolute inset-0 rounded-[34px]"></div>

            <div class="relative grid gap-4 lg:block">
              <BiomeNode
                title="Notes / 思维之枝"
                subtitle={`${noteCount}+ public notes，持续沉淀知识与观点`}
                description="它不是文档仓库，而是你把输入转成长期养分的地方。"
                href="/notes"
                accent="#63f2da"
                glow="rgba(99,242,218,0.34)"
                icon={NotebookText}
                chips={noteSamples}
                eyebrow="Mind"
                positionClass="lg:left-1/2 lg:top-8 lg:-translate-x-1/2"
              />

              <BiomeNode
                title="Builds / 创造之枝"
                subtitle={`${buildCount || 1} active artifacts，项目、代码与产品`}
                description="想法在这里落地成作品，工程感和表达欲一起发芽。"
                href={recentProject?.href || '/services'}
                accent="#59f28f"
                glow="rgba(89,242,143,0.28)"
                icon={Wrench}
                chips={buildSamples}
                eyebrow="Craft"
                positionClass="lg:left-[5%] lg:top-32"
              />

              <BiomeNode
                title="Games / 游戏"
                subtitle={`${entertainmentCount || 3} entertainment traces，沉浸与体验`}
                description="游戏不是逃离现实，而是你体验系统、叙事与世界设计的入口。"
                href="/discover?scope=notes&q=游戏"
                accent="#d48bff"
                glow="rgba(212,139,255,0.28)"
                icon={Gamepad2}
                chips={gameSamples}
                eyebrow="Play"
                positionClass="lg:right-[4%] lg:top-36"
              />

              <BiomeNode
                title="Movies / 电影"
                subtitle="镜头、叙事、情绪残响"
                description="电影分支承接审美与感受，让你不是只会写代码的人。"
                href="/discover?scope=notes&q=电影"
                accent="#7dc6ff"
                glow="rgba(125,198,255,0.28)"
                icon={Film}
                chips={movieSamples}
                eyebrow="Cinema"
                positionClass="lg:left-[3%] lg:top-[21rem]"
              />

              <BiomeNode
                title="Music / 音乐"
                subtitle="播放列表、氛围、记忆触发器"
                description="音乐像树上的孢子层，负责保存一段时间里反复回放的心境。"
                href="/discover?scope=notes&q=音乐"
                accent="#ffbc63"
                glow="rgba(255,188,99,0.26)"
                icon={Music4}
                chips={musicSamples}
                eyebrow="Mood"
                positionClass="lg:right-[5%] lg:top-[21rem]"
              />

              <BiomeNode
                title="Life / 生活"
                subtitle={`${lifeCount || 3} life traces，慢一点也算继续生长`}
                description="生活分支保存身体、情绪、购物、饮食和那些不必高产也值得被记住的部分。"
                href="/discover?scope=notes&q=life"
                accent="#90f7b6"
                glow="rgba(144,247,182,0.24)"
                icon={Leaf}
                chips={lifeSamples}
                eyebrow="Daily"
                compact={true}
                positionClass="lg:left-[9%] lg:top-[33rem]"
              />

              <BiomeNode
                title="Lab / 实验侧枝"
                subtitle={`${labCount || 1} infrastructure nodes，VPS / 网络 / 折腾`}
                description="它依然重要，但它只是生态中的一个物种，而不是你的全部身份。"
                href={recentInfra?.href || '/infrastructure'}
                accent="#53f6e0"
                glow="rgba(83,246,224,0.24)"
                icon={FlaskConical}
                chips={labSamples.length > 0 ? labSamples : ['Docker', 'VPS', 'Automation']}
                eyebrow="Lab"
                compact={true}
                positionClass="lg:right-[11%] lg:top-[33rem]"
              />

              <BiomeNode
                title="About / 年轮"
                subtitle="时间线、履历与自我介绍"
                description="如果树有年轮，这里就是你如何一步步长成现在的样子。"
                href="/about"
                accent="#62d5ff"
                glow="rgba(98,213,255,0.22)"
                icon={UserRound}
                chips={['Timeline', 'Resume']}
                eyebrow="Self"
                compact={true}
                positionClass="lg:right-[13%] lg:top-[41rem]"
              />
            </div>

            <div class="pointer-events-none absolute left-1/2 top-[4.5rem] hidden h-[46rem] w-[36rem] -translate-x-1/2 lg:block">
              <div class="biome-canopy absolute left-1/2 top-0 h-64 w-64 -translate-x-1/2"></div>
              <div class="biome-canopy absolute left-[18%] top-[4.5rem] h-52 w-52"></div>
              <div class="biome-canopy absolute right-[16%] top-22 h-56 w-56"></div>
              <div class="biome-canopy absolute left-[27%] top-36 h-44 w-44"></div>
              <div class="biome-canopy absolute right-[24%] top-40 h-48 w-48"></div>

              <span class="biome-branch-line left-[50%] top-28 w-40 -rotate-[18deg]"></span>
              <span class="biome-branch-line left-[30%] top-36 w-36 rotate-[18deg]"></span>
              <span class="biome-branch-line left-[18%] top-56 w-48 rotate-[12deg]"></span>
              <span class="biome-branch-line right-[18%] top-52 w-48 -rotate-[14deg]"></span>
              <span class="biome-branch-line right-[28%] top-36 w-36 -rotate-[18deg]"></span>
              <span class="biome-branch-line left-[37%] top-[24rem] w-28 rotate-[20deg]"></span>
              <span class="biome-branch-line right-[36%] top-[24rem] w-28 -rotate-[20deg]"></span>
              <span class="biome-branch-line right-[36%] top-[31rem] w-24 -rotate-[12deg]"></span>

              <div class="biome-trunk absolute left-1/2 top-28 h-[28rem] w-[7.5rem] -translate-x-1/2 rounded-[999px]"></div>
              <div class="biome-core-mark absolute left-1/2 top-[23rem] -translate-x-1/2">
                <span class="biome-core-ring">
                  <Leaf size={30} />
                </span>
              </div>

              <span class="biome-root-line left-[46%] bottom-14 w-56 -rotate-[11deg]"></span>
              <span class="biome-root-line left-[31%] bottom-8 w-44 rotate-[8deg]"></span>
              <span class="biome-root-line left-[50%] bottom-6 w-44"></span>
              <span class="biome-root-line right-[30%] bottom-8 w-44 -rotate-[8deg]"></span>
              <span class="biome-root-line right-[45%] bottom-14 w-56 rotate-[11deg]"></span>
            </div>

            <div class="relative z-10 mt-6 flex justify-center pt-8 lg:mt-[42rem] lg:pt-[4.5rem]">
              <div class="w-full max-w-6xl">
                <BiomeSearch discoverPath="/discover" />
              </div>
            </div>
          </div>
        </div>

        <section class="mt-8 rounded-[32px] border border-white/10 bg-slate-950/35 px-4 py-6 backdrop-blur-xl sm:px-6 lg:mt-10 lg:px-8 lg:py-8">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <div class="flex items-center gap-2 text-emerald-200/78">
                <Leaf size={16} />
                <span class="text-sm uppercase tracking-[0.3em]">Recent Growth</span>
              </div>
              <h2 class="mt-3 text-2xl font-semibold tracking-tight text-white sm:text-3xl">
                近期萌芽
              </h2>
              <p class="mt-2 max-w-2xl text-sm leading-7 text-white/54 sm:text-base">
                首页不再平铺栏目，而是让最近真的在发生的思考、项目和实验先冒出土壤。
              </p>
            </div>

            <a href="/discover" class="biome-nav-pill self-start sm:self-auto">
              <Archive size={16} />
              <span>View all</span>
            </a>
          </div>

          <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
            {recentGrowth.map((item) => (
              <RecentGrowthCard
                title={item.title}
                excerpt={item.excerpt}
                meta={item.meta}
                label={item.label}
                href={item.href}
                accent={item.accent}
                glow={item.glow}
                icon={item.icon}
                tone={item.tone}
              />
            ))}
          </div>
        </section>

        <section class="mt-8 rounded-[28px] border border-white/10 bg-slate-950/32 px-4 py-5 backdrop-blur-xl sm:px-6">
          <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex items-start gap-4">
              <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.04] text-white/72">
                <Mail size={20} />
              </span>
              <div>
                <p class="text-sm uppercase tracking-[0.28em] text-white/40">来信通道</p>
                <a href={`mailto:${contactEmail}`} class="mt-2 inline-block text-lg text-white/88 transition hover:text-emerald-200">
                  {contactEmail}
                </a>
                <p class="mt-1 text-sm text-white/46">
                  从这里继续进入 Archive、About，或者直接在根部搜索里挖掘整站内容。
                </p>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <a href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer" class="biome-icon-link" aria-label="GitHub">
                <Github size={18} />
              </a>
              <a href="/notes" class="biome-icon-link" aria-label="Notes">
                <NotebookText size={18} />
              </a>
              <a href="/about" class="biome-icon-link" aria-label="About">
                <UserRound size={18} />
              </a>
            </div>
          </div>
        </section>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const hero = document.getElementById('biome-hero');

  if (hero && window.matchMedia('(pointer:fine)').matches) {
    hero.addEventListener('pointermove', (event) => {
      const rect = hero.getBoundingClientRect();
      const x = ((event.clientX - rect.left) / rect.width) * 100;
      const y = ((event.clientY - rect.top) / rect.height) * 100;
      hero.style.setProperty('--pointer-x', `${x}%`);
      hero.style.setProperty('--pointer-y', `${y}%`);
    });

    hero.addEventListener('pointerleave', () => {
      hero.style.removeProperty('--pointer-x');
      hero.style.removeProperty('--pointer-y');
    });
  }
</script>
