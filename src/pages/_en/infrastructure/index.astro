---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import InfrastructureShowcase from '../../../components/assets/InfrastructureShowcase.astro';
import {
  featuredInfrastructureAssetIds,
  getInfrastructureDataset,
  getTopologyFactCounts,
  getTopologyFlows,
  homelabFlowIds,
  pickAssetCardsByIds,
  publicFleetFlowIds,
} from '../../../utils/infrastructure';

const { assetCards, resolvedNodes } = getInfrastructureDataset('/en');
const fleetFlows = getTopologyFlows(publicFleetFlowIds);
const homelabFlows = getTopologyFlows(homelabFlowIds);
const fleetFacts = getTopologyFactCounts(fleetFlows);
const homelabFacts = getTopologyFactCounts(homelabFlows);
const featuredAssets = pickAssetCardsByIds(assetCards, featuredInfrastructureAssetIds);

const heroFacts = [
  '4 public regions: Chengdu, Hong Kong, Japan, Korea',
  `${fleetFacts.flowCount} public lanes across control, workload, proxy, and showcase planes`,
  `${homelabFacts.flowCount} homelab lanes across power, network, compute, virtualization, and service layers`,
  `${assetCards.length} asset-backed nodes with detail, entry, and monitor jumps`,
];
---

<BaseLayout title="Infrastructure" description="Public and home infrastructure assets">
  <main class="mx-auto max-w-7xl px-4 py-10 md:px-6 md:py-14">
    <InfrastructureShowcase
      title="Digital Infrastructure Atlas"
      description="This page treats your public control plane, regional VPS fleet, public sites, home network, and homelab services as one coherent personal infrastructure showcase instead of scattered cards."
      heroFacts={heroFacts}
      featuredAssets={featuredAssets}
      resolvedNodes={resolvedNodes}
      locale="en"
    />
  </main>
</BaseLayout>
