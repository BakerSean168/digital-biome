---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FleetRegionMatrix from '../../../components/assets/FleetRegionMatrix.astro';
import {
  fleetRegionCards,
  getAssetCardsForFlows,
  getInfrastructureDataset,
  getTopologyFlows,
  publicFleetFlowIds,
} from '../../../utils/infrastructure';

const fleetFlows = getTopologyFlows(publicFleetFlowIds);
const { assetCards, resolvedNodes } = getInfrastructureDataset('/en');
const fleetAssets = getAssetCardsForFlows(fleetFlows, assetCards);
---

<BaseLayout title="Fleet" description="Public control plane, regional VPS nodes, and public sites">
  <main class="mx-auto max-w-7xl px-4 py-10 md:px-6 md:py-14">
    <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-primary/75">Infrastructure Detail</p>
        <h1 class="mt-2 text-3xl font-semibold text-foreground md:text-4xl">Fleet View</h1>
        <p class="mt-3 max-w-3xl text-sm leading-6 text-muted-foreground md:text-base">
          This page expands the public fleet into a control plane, workload plane, proxy plane, and showcase plane so the VPS footprint reads as an intentional fleet.
        </p>
      </div>
      <a href="/en/infrastructure" class="text-sm text-primary transition-colors hover:text-foreground">
        Back to infrastructure overview
      </a>
    </div>

    <FleetRegionMatrix
      title="Public Fleet and Service Entry Map"
      description="This page reworks the public infrastructure into a true region matrix, where every position is encoded by region, provider, and role instead of reading like a plain VPS list."
      regions={fleetRegionCards}
      assets={fleetAssets}
      resolvedNodes={resolvedNodes}
      locale="en"
    />
  </main>
</BaseLayout>
